# OpenJKDF2 multiplayer defaults (edit on PC, save as mp.conf on the device).
# Path: openjkdf2/conf/mp.conf

[join]
# IP or IP:port of the host PC when using Join Game on a handheld.
host=172.0.0.1:27020
password=

[character]
# Multiplayer character (New Character / Load Character screens).
# name: MPC filename under player/<profile>/ — no keyboard needed on handheld.
# rank: Jedi rank 0–8 (default for New Character; adjust in-game with arrows).
name=Kyle
rank=0

[host]
# Defaults for Start Game (create a new match).
game_name=Handheld LAN
max_players=4
port=27020
episode=JK1MP.gob
map=m2.jkl
max_rank=8
score_limit=10
time_limit=10
teams=0
single_level=1
tick_rate=20
password=
dedicated=0
coop=0
