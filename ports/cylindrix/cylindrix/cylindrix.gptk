start = enter
guide = escape

# Movimientos
up = up
down = down
left = left
right = right

# Movimiento analógico igual al D-Pad
left_analog_up = up
left_analog_down = down
left_analog_left = left
left_analog_right = right

# Acciones del juego — se asume que el port escucha teclado directamente
a = a                # Acelerar (modo aire)
b = z                # Decelerar (modo aire)
x = x                # Arma especial
y = v                # Cambiar vista
l1 = leftalt         # Sidestep
l2 = s               # Cambio modo (aire/tierra)
r1 = leftctrl     # Fire laser
r2 = space           # Fire missile

# (Opcional) Si usas más botones de gamepad:
l3 = mouse_left
r3 = mouse_right
