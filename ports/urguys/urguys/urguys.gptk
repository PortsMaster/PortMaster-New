back = esc

# Player 1: left analog stick -> WASD
left_analog_up = w
left_analog_down = s
left_analog_left = a
left_analog_right = d

# Player 2: right analog stick -> IJKL
right_analog_up = i
right_analog_down = k
right_analog_left = j
right_analog_right = l

# Player 3: dpad -> arrow keys
up = up
down = down
left = left
right = right

# Player 4: face buttons (Y up, A down, X left, B right) -> TFGH
x = t
b = g
y = f
a = h

# Start -> Enter (UI confirm)
start = enter

# Pink Guy mode shoulders/triggers
l1 = q
r1 = e
l2 = z
r2 = c

# Exit hotkey: Select+Start
hotkey = select
back hotkey = quit
start hotkey = quit

deadzone_mode = axial
deadzone = 1500
deadzone_delay = 16