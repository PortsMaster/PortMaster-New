msgid "List bans"
msgstr "Näytä luettelo porttikielloista"

msgid "Ban list: @1"
msgstr "Porttikiellot: @1"

msgid "Players can't be killed right now, damage has been disabled."
msgstr "Pelaajia ei voi tappaa. Vahingoittuminen on kytketty pois."

msgid "Player @1 does not exist."
msgstr "Pelaajaa @1 ei ole olemassa."

msgid "You are already dead"
msgstr "Olet jo kuollut"

msgid "@1 is already dead"
msgstr "@1 on jo kuollut"

msgid "[<name>]"
msgstr "[<nimi>]"

msgid "Kill player or yourself"
msgstr "Tapa pelaaja tai itsesi"

msgid "Show who is logged on"
msgstr "Näytä luettelo paikallaolijoista"

msgid "Can use /say"
msgstr "Voi käyttää /say"

msgid "<message>"
msgstr "<viesti>"

msgid "Send a message to every player"
msgstr "Lähetä viesti kaikille pelaajille"

msgid "Invalid usage, see /help say."
msgstr "Virheellinen käyttötapa. Katso /help say."

msgid "Displays the world seed"
msgstr "Näyttää maailman siemenen"

msgid "<X>,<Y>,<Z> <NodeString>"
msgstr "<X>,<Y>,<Z> <Kuutionimike>"

msgid "Set node at given position"
msgstr "Aseta kuutio tiettyyn sijaintiin"

msgid "Invalid node"
msgstr "Virheellinen kuutio"

msgid "@1 spawned."
msgstr "@1 synnytetty."

msgid "Invalid parameters (see /help setblock)"
msgstr "Virheelliset muuttujat (katso /help setblock)"

msgid "<sound> <target>"
msgstr "<ääni> <kohde>"

msgid "Play a sound. Arguments: <sound>: name of the sound. <target>: Target."
msgstr "Toista ääni. Muuttujat: <ääni>: äänen nimi. <kohde>: kohde."

msgid "Sound name is invalid!"
msgstr "Äänen nimi on virheellinen!"

msgid "Target is invalid!!"
msgstr "Kohde on virheellinen!"

msgid "Only peaceful mobs allowed!"
msgstr "Vain rauhalliset olennot sallittu!"

