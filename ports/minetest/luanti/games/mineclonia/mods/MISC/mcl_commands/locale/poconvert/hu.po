msgid "List bans"
msgstr "Tiltások listája"

msgid "Ban list: @1"
msgstr "Tiltások listája: @1"

msgid "Players can't be killed right now, damage has been disabled."
msgstr "A játékosokat jelenleg nem lehet megölni, a sebzés le van tiltva."

msgid "Player @1 does not exist."
msgstr "A @1 játékos nem létezik."

msgid "You are already dead"
msgstr "Már halott vagy"

msgid "@1 is already dead"
msgstr "@1 már halott"

msgid "[<name>]"
msgstr "[<név>]"

msgid "Kill player or yourself"
msgstr "Öld meg a játékost vagy magadat"

msgid "Show who is logged on"
msgstr "Mutassa, ki van bejelentkezve"

msgid "Can use /say"
msgstr "Használhatja a /say parancsot"

msgid "<message>"
msgstr "<üzenet>"

msgid "Send a message to every player"
msgstr "Üzenet küldése minden játékosnak"

msgid "Invalid usage, see /help say."
msgstr "Érvénytelen használat, lásd: /help say."

msgid "Displays the world seed"
msgstr "Megjeleníti a világ magját"

msgid "<X>,<Y>,<Z> <NodeString>"
msgstr "<X>,<Y>,<Z> <Csomópont>"

msgid "Set node at given position"
msgstr "Csomópont elhelyezése a megadott pozíción"

msgid "Invalid node"
msgstr "Érvénytelen csomópont"

msgid "@1 spawned."
msgstr "@1 megjelent."

msgid "Invalid parameters (see /help setblock)"
msgstr "Érvénytelen paraméterek (lásd: /help setblock)"

msgid "<sound> <target>"
msgstr "<hang> <cél>"

msgid "Play a sound. Arguments: <sound>: name of the sound. <target>: Target."
msgstr "Hang lejátszása. Argumentumok: <hang>: a hang neve. <cél>: Cél."

msgid "Sound name is invalid!"
msgstr "A hang neve érvénytelen!"

msgid "Target is invalid!!"
msgstr "A célpont érvénytelen!!"

msgid "Only peaceful mobs allowed!"
msgstr "Csak békés mobok engedélyezettek!"

