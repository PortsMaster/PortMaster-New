msgid "Bane of Arthropods"
msgstr "Ruína dos Artrópodes"

msgid "Increases damage and applies Slowness IV to arthropod mobs (spiders, cave spiders, silverfish and endermites)."
msgstr "Aumenta o dano e aplica Lentidão IV a mobs artrópodes (aranhas, aranhas-das-cavernas, traças-prateadas e endermites)."

msgid "Channeling"
msgstr "Canalização"

msgid "Channels a bolt of lightning toward a target. Works only during thunderstorms and if target is unobstructed with opaque blocks."
msgstr ""

msgid "Curse of Vanishing"
msgstr "Maldição do Desaparecimento"

msgid "Item destroyed on death."
msgstr "Item é destruído ao morrer."

msgid "Depth Strider"
msgstr "Passos Profundos"

msgid "Increases underwater movement speed."
msgstr "Aumenta a velocidade de movimentação submersa."

msgid "Efficiency"
msgstr "Eficiência"

msgid "Increases mining speed."
msgstr "Aumenta a velocidade de mineração."

msgid "Fire Aspect"
msgstr "Aspecto Flamejante"

msgid "Sets target on fire."
msgstr "Põe fogo no alvo."

msgid "Flame"
msgstr "Chama"

msgid "Arrows set target on fire."
msgstr "Flechas incendeiam o alvo."

msgid "Fortune"
msgstr "Fortuna"

msgid "Increases certain block drops."
msgstr "Aumenta a queda de alguns blocos."

msgid "Frost Walker"
msgstr "Passos Congelantes"

msgid "Turns water beneath the player into frosted ice and prevents the damage from magma blocks."
msgstr "Transforma água abaixo do jogador em gelo e previne dano de blocos de magma."

msgid "Impaling"
msgstr "Empalamento"

msgid "Trident deals additional damage to ocean mobs."
msgstr "Tridente dá dano adicional em monstros do Oceano."

msgid "Infinity"
msgstr "Infinidade"

msgid "Shooting consumes no regular arrows."
msgstr "Atirar não consome flechas."

msgid "Knockback"
msgstr "Repulsão"

msgid "Increases knockback."
msgstr "Aumenta a repulsão."

msgid "Looting"
msgstr "Saque"

msgid "Increases mob loot."
msgstr "Aumenta o saque dos mobs."

msgid "Loyalty"
msgstr "Lealdade"

msgid "Trident returns after being thrown. Higher levels reduce return time."
msgstr "Tridente retorna após ser atirado. Níveis mais altos reduzem o tempo de retorno."

msgid "Luck of the Sea"
msgstr "Sorte do Mar"

msgid "Increases rate of good loot (enchanting books, etc.)"
msgstr ""

msgid "Lure"
msgstr "Isca"

msgid "Decreases time until rod catches something."
msgstr ""

msgid "Mending"
msgstr "Conserto"

msgid "Repair the item while gaining XP orbs."
msgstr ""

msgid "Multishot"
msgstr "Alvejada"

msgid "Shoot 3 arrows at the cost of one."
msgstr ""

msgid "Piercing"
msgstr "Perfuração"

msgid "Arrows passes through multiple objects."
msgstr ""

msgid "Power"
msgstr "Força"

msgid "Increases arrow damage."
msgstr ""

msgid "Punch"
msgstr "Impacto"

msgid "Increases arrow knockback."
msgstr ""

msgid "Quick Charge"
msgstr "Carregamento Rápido"

msgid "Decreases crossbow charging time."
msgstr ""

msgid "Respiration"
msgstr "Respiração"

msgid "Extends underwater breathing time."
msgstr ""

msgid "Riptide"
msgstr "Contracorrente"

msgid "Trident launches player with itself when thrown. Works only in water or rain."
msgstr ""

msgid "Sharpness"
msgstr "Afiação"

msgid "Increases damage."
msgstr "Aumenta dano."

msgid "Silk Touch"
msgstr "Toque Suave"

msgid "Mined blocks drop themselves."
msgstr ""

msgid "Smite"
msgstr "Corta-morto"

msgid "Increases damage to undead mobs."
msgstr ""

msgid "Soul Speed"
msgstr "Velocidade das Almas"

msgid "Increases walking speed on soul sand."
msgstr ""

msgid "Sweeping Edge"
msgstr "Alto Alcance de Corte"

msgid "Increases sweeping attack damage."
msgstr ""

msgid "Unbreaking"
msgstr "Inquebrável"

msgid "Increases item durability."
msgstr ""

msgid "Density"
msgstr "Densidade"

msgid "Increases mace damage when falling."
msgstr ""

msgid "Breach"
msgstr "Ruptura"

msgid "Reduces target's armor effectiveness."
msgstr ""

msgid "Wind Burst"
msgstr "Explosão de Vento"

msgid "Emits a burst of wind from a mace smash attack."
msgstr ""

