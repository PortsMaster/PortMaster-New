msgid "Bane of Arthropods"
msgstr "Ízeltlábúak Átka"

msgid "Increases damage and applies Slowness IV to arthropod mobs (spiders, cave spiders, silverfish and endermites)."
msgstr "Növeli a sebzést és Lassúság IV-et ad az ízeltlábú moboknak (pókok, barlangi pókok, ezüsthalak és endermitek)."

msgid "Channeling"
msgstr "Csatornázás"

msgid "Channels a bolt of lightning toward a target. Works only during thunderstorms and if target is unobstructed with opaque blocks."
msgstr "Egy villámcsapást irányít a cél felé. Csak viharban működik, és a célpontnak nem szabad átlátszatlan blokkokkal akadályozottnak lennie."

msgid "Curse of Vanishing"
msgstr "Eltűnés Átka"

msgid "Item destroyed on death."
msgstr "A tárgy elvész a halálkor."

msgid "Depth Strider"
msgstr "Mélyúszó"

msgid "Increases underwater movement speed."
msgstr "Növeli a víz alatti mozgási sebességet."

msgid "Efficiency"
msgstr "Hatékonyság"

msgid "Increases mining speed."
msgstr "Növeli a bányászási sebességet."

msgid "Fire Aspect"
msgstr "Tűzes Pác"

msgid "Sets target on fire."
msgstr "Tűzbe borítja a célt."

msgid "Flame"
msgstr "Láng"

msgid "Arrows set target on fire."
msgstr "A nyilak tüzet okoznak a célnál."

msgid "Fortune"
msgstr "Szerencse"

msgid "Increases certain block drops."
msgstr "Növeli bizonyos blokkok esését."

msgid "Frost Walker"
msgstr "Jeges Pác"

msgid "Turns water beneath the player into frosted ice and prevents the damage from magma blocks."
msgstr "A játékos alatti vizet jéggé fagyasztja, és megakadályozza a magma blokkok okozta sérülést."

msgid "Impaling"
msgstr "Átdöfés"

msgid "Trident deals additional damage to ocean mobs."
msgstr "A háromágú dárda extra sebzést okoz óceáni moboknak."

msgid "Infinity"
msgstr "Végtelen"

msgid "Shooting consumes no regular arrows."
msgstr "A lövés nem fogyaszt hagyományos nyilakat."

msgid "Knockback"
msgstr "Visszalökés"

msgid "Increases knockback."
msgstr "Növeli a visszalökést."

msgid "Looting"
msgstr "Szerzemény"

msgid "Increases mob loot."
msgstr "Növeli a mobok esését."

msgid "Loyalty"
msgstr "Hűség"

msgid "Trident returns after being thrown. Higher levels reduce return time."
msgstr "A háromágú dárda visszatér a dobás után. A magasabb szint csökkenti a visszatérés idejét."

msgid "Luck of the Sea"
msgstr "Tenger Szerencséje"

msgid "Increases rate of good loot (enchanting books, etc.)"
msgstr "Növeli a jó zsákmány esélyét (varázskönyvek stb.)"

msgid "Lure"
msgstr "Csali"

msgid "Decreases time until rod catches something."
msgstr "Csökkenti az időt, amíg a bot elkap valamit."

msgid "Mending"
msgstr "Javítás"

msgid "Repair the item while gaining XP orbs."
msgstr "Javítja a tárgyat XP gömbök szerzése közben."

msgid "Multishot"
msgstr "Többlövetű"

msgid "Shoot 3 arrows at the cost of one."
msgstr "Három nyílvesszőt lő egy áráért."

msgid "Piercing"
msgstr "Áthatás"

msgid "Arrows passes through multiple objects."
msgstr "A nyilak több objektumon áthatolnak."

msgid "Power"
msgstr "Erő"

msgid "Increases arrow damage."
msgstr "Növeli a nyilak sebzését."

msgid "Punch"
msgstr "Ütés"

msgid "Increases arrow knockback."
msgstr "Növeli a nyilak visszalökését."

msgid "Quick Charge"
msgstr "Gyors Töltés"

msgid "Decreases crossbow charging time."
msgstr "Csökkenti a számszeríj töltési idejét."

msgid "Respiration"
msgstr "Légzés"

msgid "Extends underwater breathing time."
msgstr "Hosszabbítja a víz alatti lélegzést."

msgid "Riptide"
msgstr "Áradat"

msgid "Trident launches player with itself when thrown. Works only in water or rain."
msgstr "A háromágú dárda magával indítja a játékost, ha eldobják. Csak vízben vagy esőben működik."

msgid "Sharpness"
msgstr "Élesség"

msgid "Increases damage."
msgstr "Növeli a sebzést."

msgid "Silk Touch"
msgstr "Selyem Érintés"

msgid "Mined blocks drop themselves."
msgstr "A kibányászott blokkok magukat adják."

msgid "Smite"
msgstr "Gyilok"

msgid "Increases damage to undead mobs."
msgstr "Növeli a sebzést a nemholtak ellen."

msgid "Soul Speed"
msgstr "Lélek Sebesség"

msgid "Increases walking speed on soul sand."
msgstr "Növeli a lépési sebességet a lélekszárazságon."

msgid "Sweeping Edge"
msgstr "Söprő Él"

msgid "Increases sweeping attack damage."
msgstr "Növeli a söprőcsapás sebzését."

msgid "Unbreaking"
msgstr "Törhetetlenség"

msgid "Increases item durability."
msgstr "Növeli a tárgy tartósságát."

msgid "Density"
msgstr "Sűrűség"

msgid "Increases mace damage when falling."
msgstr "Növeli a buzogány sebzését zuhanás közben."

msgid "Breach"
msgstr "Törés"

msgid "Reduces target's armor effectiveness."
msgstr "Csökkenti a célpont páncéljának hatékonyságát."

msgid "Wind Burst"
msgstr "Szélroham"

msgid "Emits a burst of wind from a mace smash attack."
msgstr "Egy buzogánycsapásból származó szélrohamot bocsát ki."

msgid "Unknown Enchantment"
msgstr "Ismeretlen varázslat"

msgid "Inventory"
msgstr "Eszköztár"

msgid "@1 Enchantment Levels"
msgstr "@1 varázslatszint"

msgid "Level requirement: @1"
msgstr "Szükséges szint: @1"

msgid "@1 Lapis Lazuli"
msgstr "@1 Lápisz lazuli"

msgid "Enchant an item"
msgstr "Varázsolj meg egy tárgyat"

msgid "<player> <enchantment> [<level>]"
msgstr "<játékos> <varázslat> [<szint>]"

msgid "Usage: /enchant <player> <enchantment> [<level>]"
msgstr "Használat: /enchant <játékos> <varázslat> [<szint>]"

msgid "Player '@1' cannot be found."
msgstr "A '@1' játékos nem található."

msgid "There is no such enchantment '@1'."
msgstr "Nincs ilyen '@1' varázslat."

msgid "The target doesn't hold an item."
msgstr "A célpont nem tart tárgyat."

msgid "The selected enchantment can't be added to the target item."
msgstr "A kiválasztott varázslat nem adható a célpont tárgyához."

msgid "'@1' is not a valid number"
msgstr "'@1' nem érvényes szám"

msgid "The number you have entered (@1) is too big, it must be at most @2."
msgstr "A megadott szám (@1) túl nagy, legfeljebb @2 lehet."

msgid "The number you have entered (@1) is too small, it must be at least @2."
msgstr "A megadott szám (@1) túl kicsi, legalább @2 kell legyen."

msgid "@1 can't be combined with @2."
msgstr "@1 nem kombinálható @2-vel."

msgid "Enchanting succeded."
msgstr "A varázslás sikeres volt."

msgid "Forcefully enchant an item"
msgstr "Tárgy erőszakos varázslása"

msgid "Usage: /forceenchant <player> <enchantment> [<level>]"
msgstr "Használat: /forceenchant <játékos> <varázslat> [<szint>]"

msgid "The target item is not enchantable."
msgstr "A célpont tárgya nem varázsolható."

msgid "'@1' is not a valid number."
msgstr "'@1' nem érvényes szám."

msgid "Enchanted Book"
msgstr "Elvarászolt könyv"

msgid "Enchanting Table"
msgstr "Varázslóasztal"

msgid "Spend experience, and lapis to enchant various items."
msgstr "Tapasztalat és lápisz lazuli felhasználásával varázsolj különböző tárgyakat."

msgid "Enchanting Tables will let you enchant armors, tools, weapons, and books with various abilities. But, at the cost of some experience, and lapis lazuli."
msgstr "A varázslóasztalok lehetővé teszik páncélok, szerszámok, fegyverek és könyvek varázslását különböző képességekkel. De tapasztalatot és lápisz lazulit igényelnek."

msgid "Rightclick the Enchanting Table to open the enchanting menu."
msgstr "Jobbklikk a varázslóasztalon a varázslási menü megnyitásához."

msgid "Place a tool, armor, weapon or book into the top left slot, and then place 1-3 Lapis Lazuli in the slot to the right."
msgstr "Helyezz el egy szerszámot, páncélt, fegyvert vagy könyvet a bal felső mezőbe, majd tegyél 1-3 Lápisz lazulit a jobb oldali mezőbe."

msgid "After placing your items in the slots, the enchanting options will be shown. Hover over the options to read what is available to you."
msgstr "Miután elhelyezted a tárgyakat, a varázslási lehetőségek megjelennek. Vidd az egeret a lehetőségek fölé, hogy elolvasd, mi érhető el."

msgid "These options are randomized, and dependent on experience level; but the enchantment strength can be increased."
msgstr "Ezek a lehetőségek véletlenszerűek, a tapasztalati szinttől függenek; de a varázslat ereje növelhető."

msgid "To increase the enchantment strength, place bookshelves around the enchanting table. However, you will need to keep 1 air node between the table, & the bookshelves to empower the enchanting table."
msgstr "A varázslat erejének növeléséhez helyezz könyvespolcokat a varázslóasztal köré. Tarts 1 légrést az asztal és a polcok között, hogy a varázslóasztalt megerősítsd."

msgid "After finally selecting your enchantment; left-click on the selection, and you will see both the lapis lazuli and your experience levels consumed. And, an enchanted item left in its place."
msgstr "Miután kiválasztottad a varázslatot, bal klikkel kattints rá, és látni fogod, hogy a lápisz lazuli és a tapasztalati szinted felhasználásra kerül. Egy elvarázsolt tárgy marad a helyén."

msgid "Enchant"
msgstr "Varázslás"

