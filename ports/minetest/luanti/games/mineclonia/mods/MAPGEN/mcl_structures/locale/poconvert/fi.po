msgid "Generate a pre-defined structure near your position."
msgstr "Luo ennalta määritetty rakennus sijaintisi lähelle."

msgid "Structure placed."
msgstr "Rakennus sijoitettu."

msgid "Error: No structure type given. Please use “/spawnstruct <type>”."
msgstr "Virhe: Rakennusta ei annettu. Käytä kaavaa \"/spawnstruct <rakennus>\"."

msgid "Error: Unknown structure type. Please use “/spawnstruct <type>”."
msgstr "Virhe: Tuntematon rakennus. Käytä kaavaa \"/spawnstruct <rakennus>\"."

msgid "Use /help spawnstruct to see a list of available types."
msgstr "Käytä komentoa /help spawnstruct nähdäksesi luettelon saatavilla olevista rakennuksista."

