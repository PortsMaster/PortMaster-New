msgid "This is the help."
msgstr "Tämä on opas."

msgid "All help entries revealed!"
msgstr "Kaikki oppaan tekstit paljastettu!"

msgid "All help entries are already revealed."
msgstr "Kaikki oppaan tekstit on jo paljastettu."

msgid "Category list"
msgstr "Kategoriat"

msgid "Entry list"
msgstr "Tekstit"

msgid "Entry"
msgstr "Teksti"

msgid "Error: No help available."
msgstr "Virhe: Ei opasta saatavilla."

msgid "No categories have been registered, but they are required to provide help."
msgstr "Kategorioita ei ole merkitty. Ne tarvitaan, jotta opas toimii."

msgid "The Documentation System [doc] does not come with help contents on its own, it needs additional mods to add help content. Please make sure such mods are enabled on for this world, and try again."
msgstr "The Documentation System [doc] -lisäosa ei itsessään sisällä opastekstejä, vaan niitä varten tarvitaan erillisiä lisäosia. Varmista, että kyseiset lisäosat on aktivoitu tässä maailmassa, ja yritä uudelleen."

msgid "Recommended mods: doc_basics, doc_items, doc_identifier, doc_encyclopedia."
msgstr "Suositellut lisäosat: doc_basics, doc_items, doc_identifier, doc_encyclopedia."

msgid "Error: Access denied."
msgstr "Virhe: Ei käyttöoikeutta."

msgid "Access to the requested entry has been denied; this entry is secret. You may unlock access by progressing in the game. Figure out on your own how to unlock this entry."
msgstr "Sinulla ei ole oikeutta avata tätä tekstiä, koska se on salainen. Se saattaa avautua, kun etenet pelissä. Sinun tulee selvittää itse, miten tämä teksti avataan."

msgid "Nameless entry (@1)"
msgstr "Nimetön teksti (@1)"

msgid "Help > @1"
msgstr "Opas > @1"

msgid "Currently all entries in this category are hidden from you."
msgstr "Tällä hetkellä kaikki tämän kategorian tekstit on piilotettu."

msgid "Unlock new entries by progressing in the game."
msgstr "Avaa uusia tekstejä etenemällä pelissä."

msgid "Number of entries: @1"
msgstr "Tekstien määrä: @1"

msgid "New entries: @1"
msgstr "Uusia tekstejä: @1"

msgid "Hidden entries: @1"
msgstr "Piilotettuja tekstejä: @1"

msgid "Help > @1 > (No Entry)"
msgstr "Opas > @1 > (Ei tekstiä)"

msgid "Help > @1 > @2"
msgstr "Opas > @1 > @2"

msgid "Open a window providing help entries about Minetest and more"
msgstr "Avaa ikkuna, josta löytyy opastekstejä Minetestiin ja muuhun liittyen"

msgid "Allows you to reveal all hidden help entries with /help_reveal"
msgstr "Antaa sinun paljastaa kaikki piilotetut opastekstit komennolla /help_reveal"

msgid "Reveal all hidden help entries to you"
msgstr "Paljasta kaikki piilotetut opastekstit"

