msgid "@1 went up in flames"
msgstr "@1 foi incendiado"

msgid "@1 walked into fire whilst fighting @2"
msgstr "@1 entrou no fogo enquanto lutava contra @2"

msgid "@1 was struck by lightning"
msgstr "@1 foi atingido por um raio"

msgid "@1 was struck by lightning whilst fighting @2"
msgstr "@1 foi atingido por um raio enquanto lutava contra @2"

msgid "@1 burned to death"
msgstr "@1 morreu queimado"

msgid "@1 was burnt to a crisp whilst fighting @2"
msgstr "@1 ficou completamente carbonizado durante a luta contra @2"

msgid "@1 tried to swim in lava"
msgstr "@1 tentou nadar em lava"

msgid "@1 tried to swim in lava to escape @2"
msgstr "@1 tentou nadar na lava para escapar de @2"

msgid "@1 discovered the floor was lava"
msgstr "@1 descobriu que o chão era lava"

msgid "@1 walked into danger zone due to @2"
msgstr "@1 entrou em zona de perigo devido a @2"

msgid "@1 suffocated in a wall"
msgstr "@1 sufocou em uma parede"

msgid "@1 suffocated in a wall whilst fighting @2"
msgstr "@1 sufocou em uma parede enquanto lutava @2"

msgid "@1 drowned"
msgstr "@1 se afogou"

msgid "@1 drowned whilst trying to escape @2"
msgstr "@1 se afogou ao tentar escapar @2"

msgid "@1 starved to death"
msgstr "@1 morreu de fome"

msgid "@1 starved to death whilst fighting @2"
msgstr "@1 morreu de fome enquanto lutava contra @2"

msgid "@1 was pricked to death"
msgstr "@1 morreu espetado"

msgid "@1 walked into a cactus whilst trying to escape @2"
msgstr "@1 entrou num cacto enquanto tentava escapar de @2"

msgid "@1 hit the ground too hard"
msgstr "@1 caiu no chão com muita força"

msgid "@1 hit the ground too hard whilst trying to escape @2"
msgstr "@1 caiu no chão com muita força ao tentar escapar @2"

msgid "@1 experienced kinetic energy"
msgstr "@1 experimentou a energia cinética"

msgid "@1 experienced kinetic energy whilst trying to escape @2"
msgstr "@1 experimentou energia cinética ao tentar escapar de @2"

msgid "@1 fell out of the world"
msgstr "@1 caiu fora do mundo"

msgid "@1 didn't want to live in the same world as @2"
msgstr "@1 não queria viver no mesmo mundo que @2"

msgid "@1 died"
msgstr "@1 morreu"

msgid "@1 died because of @2"
msgstr "@1 morreu por causa de @2"

msgid "@1 was killed by magic"
msgstr "@1 foi morto por magia"

msgid "@1 was killed by magic whilst trying to escape @2"
msgstr "@1 foi morto por magia enquanto tentava escapar de @2"

msgid "@1 was killed by @2 using magic"
msgstr "@1 foi morto por @2 usando magia"

msgid "@1 was killed by @2 using @3"
msgstr "@1 foi morto por @2 usando @3"

msgid "@1 was roasted in dragon breath"
msgstr "@1 foi torrado no hálito de dragão"

msgid "@1 was roasted in dragon breath by @2"
msgstr "@1 foi torrado no bafo de dragão por @2"

msgid "@1 withered away"
msgstr "@1 definhou"

msgid "@1 withered away whilst fighting @2"
msgstr "@1 definhou enquanto lutava contra @2"

msgid "@1 was shot by a skull from @2"
msgstr "@1 foi atingido por um crânio de @2"

msgid "@1 was squashed by a falling anvil"
msgstr "@1 foi esmagado por uma bigorna que caiu"

msgid "@1 was squashed by a falling anvil whilst fighting @2"
msgstr "@1 foi esmagado por uma bigorna que caiu enquanto lutava contra @2"

msgid "@1 was squashed by a falling block"
msgstr "@1 foi esmagado por um bloco que caiu"

msgid "@1 was squashed by a falling block whilst fighting @2"
msgstr "@1 foi esmagado por um bloco que caiu enquanto lutava contra @2"

msgid "@1 was slain by @2"
msgstr "@1 foi assassinado por @2"

msgid "@1 was slain by @2 using @3"
msgstr "@1 foi assassinado por @2 usando @3"

msgid "@1 was shot by @2"
msgstr "@1 recebeu tiro por @2"

msgid "@1 was shot by @2 using @3"
msgstr "@1 recebeu tiro por @2 usando @3"

msgid "@1 was spitballed by @2"
msgstr "@1 foi cuspido por @2"

msgid "@1 was spitballed by @2 using @3"
msgstr "@1 foi cuspido por @2 usando @3"

msgid "@1 was fireballed by @2"
msgstr "@1 sofreu uma bolada de fogo por @2"

msgid "@1 was fireballed by @2 using @3"
msgstr "@1 sofreu uma bolada de fogo por @2 usando @3"

msgid "@1 was killed trying to hurt @2"
msgstr "@1 foi morto ao tentar ferir @2"

msgid "@1 tried to hurt @2 and died by @3"
msgstr "@1 tentou ferir @2 e foi morto por @3"

msgid "@1 blew up"
msgstr "@1 explodiu"

msgid "@1 was blown up by @2"
msgstr "@1 foi explodido por @2"

msgid "@1 was blown up by @2 using @3"
msgstr "@1 foi explodido por @2 usando @3"

msgid "@1 was squished too much"
msgstr "@1 foi esmagado demais"

msgid "@1 was squashed by @2"
msgstr "@1 foi esmagado por @2"

msgid "@1 went off with a bang"
msgstr "@1 foi atingido por uma explosão"

msgid "@1 went off with a bang due to a firework fired by @2 from @3"
msgstr "@1 foi atingido pela explosão de um fogo de artifício disparado por @2 em @3"

msgid "@1 was poked to death by a sweet berry bush"
msgstr "@1 foi morto por uma planta de bagas doces"

msgid "@1 was poked to death by a sweet berry bush whilst trying to escape @2"
msgstr "@1 foi espetado até a morte por um arbusto de bagas enquanto tentava escapar de @2"

msgid "@1 froze to death"
msgstr "@1 morreu congelado"

msgid "@1 was frozen to death by @2"
msgstr "@1 morreu congelado por @2"

msgid "@1 was impaled by @2"
msgstr "@1 foi empalado por @2"

msgid "@1 was impaled by @2 with @3"
msgstr "@1 foi empalado por @2 com @3"

