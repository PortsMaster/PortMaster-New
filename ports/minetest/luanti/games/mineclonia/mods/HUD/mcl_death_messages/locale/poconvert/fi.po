msgid "@1 went up in flames"
msgstr "@1 astui liekkeihin"

msgid "@1 walked into fire whilst fighting @2"
msgstr "@1 astui liekkeihin taistelleessaan olentoa @2 vastaan"

msgid "@1 was struck by lightning"
msgstr "@1 päätyi salaman iskemäksi"

msgid "@1 was struck by lightning whilst fighting @2"
msgstr "@1 päätyi salaman iskemäksi taistellessaan olentoa @2 vastaan"

msgid "@1 burned to death"
msgstr "@1 paloi kuoliaaksi"

msgid "@1 was burnt to a crisp whilst fighting @2"
msgstr "@1 paloi karrelle taistelleessaan olentoa @2 vastaan"

msgid "@1 tried to swim in lava"
msgstr "@1 yritti uida laavassa"

msgid "@1 tried to swim in lava to escape @2"
msgstr "@1 yritti uida laavassa paetakseen olentoa @2"

msgid "@1 discovered the floor was lava"
msgstr "@1 huomasi, että lattia olikin laavaa"

msgid "@1 walked into danger zone due to @2"
msgstr "@1 astui vaaravyöhykkeelle olennon @2 takia"

msgid "@1 suffocated in a wall"
msgstr "@1 tukehtui seinään"

msgid "@1 suffocated in a wall whilst fighting @2"
msgstr "@1 tukehtui seinään taistelleessaan olentoa @2 vastaan"

msgid "@1 drowned"
msgstr "@1 hukkui"

msgid "@1 drowned whilst trying to escape @2"
msgstr "@1 hukkui yrittäessään paeta olentoa @2"

msgid "@1 starved to death"
msgstr "@1 kuoli nälkään"

msgid "@1 starved to death whilst fighting @2"
msgstr "@1 kuoli nälkään taistellessaan olentoa @2 vastaan"

msgid "@1 was pricked to death"
msgstr "@1 piikitettiin kuoliaaksi"

msgid "@1 walked into a cactus whilst trying to escape @2"
msgstr "@1 käveli päin kaktusta yrittäessään paeta olentoa @2"

msgid "@1 hit the ground too hard"
msgstr "@1 osui maahan liian lujaa"

msgid "@1 hit the ground too hard whilst trying to escape @2"
msgstr "@1 osui maahan liian lujaa yrittäessään paeta olentoa @2"

msgid "@1 experienced kinetic energy"
msgstr "@1 kohtasi liike-energiaa"

msgid "@1 experienced kinetic energy whilst trying to escape @2"
msgstr "@1 kohtasi liike-energiaa yrittäessään paeta olentoa @2"

msgid "@1 fell out of the world"
msgstr "@1 putosi maailmasta"

msgid "@1 didn't want to live in the same world as @2"
msgstr "@1 ei halunnut elää samassa maailmassa kuin @2"

msgid "@1 died"
msgstr "@1 kuoli"

msgid "@1 died because of @2"
msgstr "@1 kuoli olennon @2 takia"

msgid "@1 was killed by magic"
msgstr "@1 surmattiin taialla"

msgid "@1 was killed by magic whilst trying to escape @2"
msgstr "@1 surmattiin taialla, kun tämä yritti paeta olentoa @2"

msgid "@1 was killed by @2 using magic"
msgstr "@2 tappoi pelaajan @1 taialla"

msgid "@1 was killed by @2 using @3"
msgstr "@2 tappoi pelaajan @1 välineenään @3"

msgid "@1 was roasted in dragon breath"
msgstr "@1 paahtui ääriliskon henkäykseen"

msgid "@1 was roasted in dragon breath by @2"
msgstr "@2 paahtoi pelaajan @1 ääriliskon henkäykseen"

msgid "@1 withered away"
msgstr "@1 kuihtui"

msgid "@1 withered away whilst fighting @2"
msgstr "@1 kuihtui taistellessaan olentoa @2 vastaan"

msgid "@1 was shot by a skull from @2"
msgstr "@2 ampui pelaajan @1 pääkallolla"

msgid "@1 was squashed by a falling anvil"
msgstr "@1 litistyi putoavan alasimen alle"

msgid "@1 was squashed by a falling anvil whilst fighting @2"
msgstr "@1 litistyi putoavan alasimen alle taistellessaan olentoa @2 vastaan"

msgid "@1 was squashed by a falling block"
msgstr "@1 litistyi putoavan kuution alle"

msgid "@1 was squashed by a falling block whilst fighting @2"
msgstr "@1 litistyi putoavan kuution alle taistellessaan olentoa @2 vastaan"

msgid "@1 was slain by @2"
msgstr "@2 surmasi pelaajan @1"

msgid "@1 was slain by @2 using @3"
msgstr "@2 surmasi pelaajan @1 välineenään @3"

msgid "@1 was shot by @2"
msgstr "@2 ampui pelaajan @1"

msgid "@1 was shot by @2 using @3"
msgstr "@2 ampui pelaajan @1 välineenään @3"

msgid "@1 was spitballed by @2"
msgstr "@2 syljeksi pelaajan @1 päälle"

msgid "@1 was spitballed by @2 using @3"
msgstr "@2 syljeksi pelaajan @1 päälle välineenään @3"

msgid "@1 was fireballed by @2"
msgstr "@2 ampui pelaajan @1 tulipallolla"

msgid "@1 was fireballed by @2 using @3"
msgstr "@2 ampui pelaajan @1 tulipallolla välineenään @3"

msgid "@1 was killed trying to hurt @2"
msgstr "@1 tapettiin, kun tämä yritti vahingoittaa olentoa @2"

msgid "@1 tried to hurt @2 and died by @3"
msgstr "@3 tappoi pelaajan @1, kun tämä yritti vahingoittaa olentoa @2"

msgid "@1 blew up"
msgstr "@1 räjähti"

msgid "@1 was blown up by @2"
msgstr "@2 räjäytti pelaajan @1"

msgid "@1 was blown up by @2 using @3"
msgstr "@2 räjäytti pelaajan @1 välineenään @3"

msgid "@1 was squished too much"
msgstr "@1 likistyi liian paljon"

msgid "@1 was squashed by @2"
msgstr "@2 litisti pelaajan @1"

msgid "@1 went off with a bang"
msgstr "@1 paukahti"

msgid "@1 went off with a bang due to a firework fired by @2 from @3"
msgstr "@2 paukautti pelaajan @1 ilotulitteella välineenään @3"

msgid "@1 was poked to death by a sweet berry bush"
msgstr "@1 juuttui marjapensaaseen"

msgid "@1 was poked to death by a sweet berry bush whilst trying to escape @2"
msgstr "@1 juuttui marjapensaaseen yrittäessään paeta olentoa @2"

msgid "@1 froze to death"
msgstr "@1 jäätyi kuoliaaksi"

msgid "@1 was frozen to death by @2"
msgstr "@2 jäädytti pelaajan @1 kuoliaaksi"

msgid "@1 was impaled by @2"
msgstr "@2 lävisti pelaajan @1"

msgid "@1 was impaled by @2 with @3"
msgstr "@2 lävisti pelaajan @1 välineenään @3"

