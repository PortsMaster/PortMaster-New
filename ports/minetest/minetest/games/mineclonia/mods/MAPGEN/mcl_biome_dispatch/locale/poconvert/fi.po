msgid "Loading terrain"
msgstr "Ladataan maastoa"

msgid "Locate a structure, biome, or point of interest identified by ID in the current dimension."
msgstr "Paikanna rakennus, biomi tai muu tunnuksellinen kohde tämänhetkisestä ulottuvuudesta."

msgid "No structure of type @1 exists near your position"
msgstr "Tyypin @1 rakennusta ei ole lähistölläsi"

msgid "No biome matching @1 exists near your position"
msgstr "Lähelläsi ei ole biomia, joka sopisi tunnukseen @1"

msgid "@1 does not identify a valid point of interest"
msgstr "@1 ei ole tunnustettu kohde"

msgid "No point of interest named @1 exists near your position"
msgstr "Lähistöltäsi ei löydy kohdetta, jonka tunnus on @1"

msgid "Usage: /locate [structure | biome | poi] <ID>"
msgstr "Käyttöohjeet: /locate [structure | biome | poi] <tunnus>"

msgid "/locate structure requires a structure ID.\n"
"These structures are available: "
msgstr "/locate structure -komento vaatii rakennuksen tunnuksen.\n"
"Nämä rakennukset ovat saatavilla: "

msgid "/locate biome requires a biome ID or a tag prefixed with `#'.\n"
"These biomes and tags are available: "
msgstr "/locate biome -komento vaatii biomin tunnuksen tai liitekysymyksen, jonka edessä on #-etuliite.\n"
"Nämä biomit ja liitekysymykset ovat saatavilla: "

msgid "/locate poi requires an identifier designating a valid point of interest.\n"
"These points of interest are available: "
msgstr "/locate poi -komento vaatii kohteen tunnuksen.\n"
"Nämä kohteet ovat saatavilla: "

