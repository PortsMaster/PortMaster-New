msgid "Loading terrain"
msgstr "Chargement du terrain"

msgid "Locate a structure, biome, or point of interest identified by ID in the current dimension."
msgstr "Localisez une structure, un biome ou un point d'intérêt identifié par un identifiant dans la dimension actuelle."

msgid "No structure of type @1 exists near your position"
msgstr "Aucune structure de type @1 n'existe à proximité de votre position"

msgid "No biome matching @1 exists near your position"
msgstr "Aucun biome de type @1 n'existe à proximité de votre position"

msgid "@1 does not identify a valid point of interest"
msgstr "@1 n'identifie pas un point d'intérêt valide"

msgid "No point of interest named @1 exists near your position"
msgstr "Il n'y a aucun point d'intérêt nommé @1 à proximité de votre position"

msgid "Usage: /locate [structure | biome | poi] <ID>"
msgstr "Utilisation : /locate [structure | biome | poi] <ID>"

msgid "/locate structure requires a structure ID.\n"
"These structures are available: "
msgstr "/locate structure nécessite l'identifiant d'une structure.\n"
"Les structures suivantes sont disponibles : "

msgid "/locate biome requires a biome ID or a tag prefixed with `#'.\n"
"These biomes and tags are available: "
msgstr "/locate biome nécessite un identifiant de biome ou une balise préfixée par `#'.\n"
"Les biomes et balises suivantes sont disponibles : "

msgid "/locate poi requires an identifier designating a valid point of interest.\n"
"These points of interest are available: "
msgstr "/locate poi nécessite un identifiant désignant un point d'intérêt valide.\n"
"Les points d'intérêt suivants sont disponibles : "

