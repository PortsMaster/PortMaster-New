msgid "[<gamemode>] [<player>]"
msgstr "[<pelitila>] [<pelaaja>]"

msgid "Change gamemode (survival/creative/0/1/s/c) for yourself or player"
msgstr "Vaihda omaa tai toisen pelaajan pelitilaa (survival/creative/0/1/s/c)"

msgid "Player not online"
msgstr "Pelaaja ei ole paikalla"

msgid "Failed to set gamemode @1 for player @2"
msgstr "Pelitilan @1 asettaminen pelaajalle @2 epäonnistui"

msgid "Player @1 is still in creative mode because world is in creative mode"
msgstr "Pelaaja @1 on yhä luovalla tilalla, koska maailma on asetettu luovalle tilalle"

msgid "Gamemode for player @1: @2"
msgstr "Pelaajan @1 pelitila: @2"

