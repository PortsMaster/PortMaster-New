msgid "Stick"
msgstr "Bastono"

msgid "Sticks are a very versatile crafting material; used in countless crafting recipes."
msgstr "Bastonetoj estas tre pluruzaj materialoj; uzataj en sennombraj kunmet-receptoj."

msgid "Paper"
msgstr "Papero"

msgid "Paper is used to craft books and maps."
msgstr "Paperon oni uzas por fari librojn kaj mapojn."

msgid "Coal"
msgstr "Karbo"

msgid "“Coal” refers to coal lumps obtained by digging coal ore which can be found underground. Coal is your standard furnace fuel, but it can also be used to make torches, coal blocks and a few other things."
msgstr ""

msgid "Charcoal"
msgstr ""

msgid "Charcoal is an alternative furnace fuel created by cooking wood in a furnace. It has the same burning time as coal and also shares many of its crafting recipes, but it can not be used to create coal blocks."
msgstr ""

msgid "Iron Nugget"
msgstr ""

msgid "Iron nuggets are very small pieces of molten iron; the main purpose is to create iron ingots."
msgstr ""

msgid "Gold Nugget"
msgstr ""

msgid "Gold nuggets are very small pieces of molten gold; the main purpose is to create gold ingots."
msgstr ""

msgid "Diamond"
msgstr "Diamanto"

msgid "Diamonds are precious minerals and useful to create the highest tier of armor and tools."
msgstr ""

msgid "Diamond Material"
msgstr ""

msgid "Clay Ball"
msgstr ""

msgid "Clay balls are a raw material, mainly used to create bricks in the furnace."
msgstr ""

msgid "Iron Ingot"
msgstr ""

msgid "Molten iron. It is used to craft armor, tools, and whatnot."
msgstr "Fandita fero. Uzebla por fari armaĵon, ilojn, kaj aliaĵojn."

msgid "Iron Material"
msgstr ""

msgid "Gold Ingot"
msgstr ""

msgid "Molten gold. It is used to craft armor, tools, and whatnot."
msgstr "Fandita oro. Uzebla por fari armaĵon, ilojn, kaj aliaĵojn."

msgid "Gold Material"
msgstr ""

msgid "Emerald"
msgstr "Smeraldo"

msgid "Emeralds are used in villager trades as currency."
msgstr ""

msgid "Emerald Material"
msgstr ""

msgid "Lapis Lazuli"
msgstr ""

msgid "Lapis Lazuli are required for enchanting items on an enchanting table."
msgstr ""

msgid "Lapis Material"
msgstr ""

msgid "Brick"
msgstr "Briko"

msgid "Bricks are used to craft brick blocks."
msgstr ""

msgid "Flint"
msgstr ""

msgid "Flint is a raw material."
msgstr ""

msgid "Sugar"
msgstr "Sukero"

msgid "Sugar comes from sugar canes and is used to make sweet foods."
msgstr ""

msgid "Bowl"
msgstr "Bovlo"

msgid "Bowls are mainly used to hold tasty soups."
msgstr ""

msgid "Apple"
msgstr "Pomo"

msgid "Apples are food items which can be eaten."
msgstr "Pomoj estas nutraĵaj portaĵoj kiujn oni povas manĝi."

msgid "Golden Apple"
msgstr "Ora Pomo"

msgid "Golden apples are precious food items which can be eaten."
msgstr "Oraj pomoj estas altvaloraj portaĵoj kiujn oni povas manĝi."

msgid "Enchanted Golden Apple"
msgstr "Sorĉita Ora Pomo"

