msgstr "Gránitlap"

msgid "Diorite Stairs"
msgstr "Dioritlépcső"

msgid "Diorite Slab"
msgstr "Dioritlap"

msgid "Cobblestone Stairs"
msgstr "Zúzottkő lépcső"

msgid "Cobblestone Slab"
msgstr "Zúzottkő lap"

msgid "Mossy Cobblestone Stairs"
msgstr "Mohás kőlépcső"

msgid "Mossy Cobblestone Slab"
msgstr "Mohás kőlap"

msgid "Brick Stairs"
msgstr "Téglalépcső"

msgid "Brick Slab"
msgstr "Téglalap"

msgid "Sandstone Stairs"
msgstr "Homokkőlépcső"

msgid "Sandstone Slab"
msgstr "Homokkőlap"

msgid "Smooth Sandstone Stairs"
msgstr "Finom homokkőlépcső"

msgid "Smooth Sandstone Slab"
msgstr "Finom homokkőlap"

msgid "Cut Sandstone Stairs"
msgstr "Csiszolt homokkőlépcső"

msgid "Cut Sandstone Slab"
msgstr "Csiszolt homokkőlap"

msgid "Red Sandstone Stairs"
msgstr "Vöröshomokkő-lépcső"

msgid "Red Sandstone Slab"
msgstr "Vöröshomokkő-lap"

msgid "Smooth Red Sandstone Stairs"
msgstr "Finom vöröshomokkő-lépcső"

msgid "Smooth Red Sandstone Slab"
msgstr "Finom vöröshomokkő-lap"

msgid "Cut Red Sandstone Stairs"
msgstr "Csiszolt vöröshomokkő-lépcső"

msgid "Cut Red Sandstone Slab"
msgstr "Csiszolt vöröshomokkő-lap"

msgid "Stone Brick Stairs"
msgstr "Kőtégla-lépcső"

msgid "Stone Brick Slab"
msgstr "Kőtégla-lap"

msgid "Polished Andesite Stairs"
msgstr "Csiszolt andezitlépcső"

msgid "Polished Andesite Slab"
msgstr "Csiszolt andezitlap"

msgid "Polished Granite Stairs"
msgstr "Csiszolt gránitlépcső"

msgid "Polished Granite Slab"
msgstr "Csiszolt gránitlap"

msgid "Polished Diorite Stairs"
msgstr "Csiszolt dioritlépcső"

