msgstr "Tartósság:"

msgid "This is a melee weapon which deals damage by punching."
msgstr "Ez egy közelharcban használható fegyver, mellyel szúrni lehet."

msgid "Maximum damage per hit:"
msgstr "Legnagyobb sebzés ütésenként:"

msgid "• @1: @2 HP"
msgstr "• @1: @2 életpont"

msgid "Full punch interval: @1 s"
msgstr "Lendítési idő: @1 s"

msgid "This block can be mined by any mining tool in half a second."
msgstr "Ezt a blokkot bármely szerszámmal fél másodperc alatt lehet kitermelni."

msgid "This block can be mined by any mining tool immediately."
msgstr "Ezt a blokkot bármely szerszámmal azonnal ki lehet termelni."

msgid "This block can not be mined by ordinary mining tools."
msgstr "Ez a blokk nem bányászható ki közönséges bányászszerszámokkal."

msgid "This block can be destroyed by any mining tool in half a second."
msgstr "Ez a blokk bármilyen bányászszerszámmal megsemmisíthető fél másodperc alatt."

msgid "This block can be destroyed by any mining tool immediately."
msgstr "Ez a blokk bármilyen bányászszerszámmal azonnal megsemmisíthető."

msgid "This block can not be destroyed by ordinary mining tools."
msgstr "Ez a blokk nem semmisíthető meg közönséges bányászszerszámokkal."

msgid "This block can be mined by mining tools which match any of the following mining ratings and its toughness level."
msgstr "Ez a blokk olyan bányászszerszámokkal bányászható ki, amely megfelel a következő bányászási minősítések bármelyikének és a keménységi fokának."

msgid "Mining ratings:"
msgstr "Bányászási minősítések:"

msgid "Toughness level: @1"
msgstr "Keménységi fok: @1"

msgid "Range: @1"
msgstr "Hatótáv: @1"

msgid "Range: @1 (@2)"
msgstr "Hatótáv: @1 (@2)"

msgid "This tool can serve as a smelting fuel with a burning time of @1."
msgstr "Ez az eszköz használható olvasztóban tüzelőanyagként, @1 égési idővel."

msgid "This block can serve as a smelting fuel with a burning time of @1."
msgstr "Ez a blokk használható olvasztóban tüzelőanyagként, @1 égési idővel."

msgid "This item can serve as a smelting fuel with a burning time of @1."
msgstr "Ez a tárgy használható olvasztóban tüzelőanyagként, @1 égési idővel."

msgid " Using it as fuel turns it into: @1."
msgstr " Tüzelőanyagként való használata átalakítja: @1."

