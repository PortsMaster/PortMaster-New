msgid "Enable dust particles in the nether"
msgstr "Laita Hornan pölyhiukkaset päälle"

msgid "Gives ability to control weather"
msgstr "Antaa kyvyn säädellä säätä"

msgid "Changes the weather to the specified parameter."
msgstr "Muuttaa sään annettujen muuttujien mukaiseksi."

msgid "Error: No weather specified."
msgstr "Virhe: Säätilaa ei ole määritetty."

msgid "Error: Invalid parameters."
msgstr "Virhe: Virheelliset muuttujat."

msgid "Error: Duration can't be less than 1 second."
msgstr "Virhe: Kesto ei voi olla alle yhden (1) sekunnin."

msgid "Error: Invalid weather specified. Use “clear”, “rain”, or “thunder”."
msgstr "Virhe: Määritetty säätila on virheellinen. Käytä säätiloja \"clear\", \"rain\" tai \"thunder\"."

msgid "Toggles between clear weather and weather with downfall (randomly rain, thunderstorm or snow)"
msgstr "Vaihtaa selkeän sään ja sateisen sään välillä (satunnaisesti sade, ukkosmyrsky tai lumisade)"

