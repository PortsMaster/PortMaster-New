# Mina the Hollower — gptokeyb2 config.
#
# Mina reads the controller natively through SDL2 (gamepad mappings come from
# $sdl_controllerconfig), so gptokeyb does NOT grab the pad — it stays in
# passthrough and only provides PortMaster's standard "hold a hotkey to quit"
# overlay so players can exit on devices without a keyboard.
#
# gptokeyb is launched as `$GPTOKEYB "machismo"` from the launch script; the
# process name (machismo) selects this file.

[control]
overlay = clear
exclusive = false
