+function make_good_table(input)
+    local out = {}
+    for i,v in ipairs(input) do
+        local t = {}
+        local name = nil
+        for k,val in pairs(v) do
+            if k == 'tag' then
+                name = val
+            elseif k == 'children' then
+                for ck,cv in pairs(make_good_table(val)) do
+                    t[ck] = cv
+                end
+            elseif k == 'attrs' then
+                for ck, cv in pairs(val) do
+                    t[ck] = cv
+                end
+            else
+                t[k] = val
+            end
+        end
+        if name then
+            if name == 'properties' then
+                for i, property in ipairs(t.property) do
+                    out[property.name] = property.value
+                end
+            else
+                if not out[name] then
+                    out[name] = {}
+                end
+                table.insert(out[name], t)
+            end
+        elseif v.attrs and v.attrs.name then
+            name = v.attrs.name
+            out[name] = t
+        else
+            return t
+        end
+    end
+    return out
+end
