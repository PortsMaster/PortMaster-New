+function GameScene:next(fancy_exit, fancy_enter, greed)
+    if self.back then
+        change_scene(self.back)
+        return
+    end
+
+    if greed then
+        SAVE.BEAT[''..SAVE.LEVEL_NUM] = 'greed'
+    elseif SAVE.GREED ~= 0 then
+        SAVE.BEAT[''..(SAVE.LEVEL_NUM+SAVE.GREED*0.01)] = true
+    else
+        SAVE.BEAT[''..SAVE.LEVEL_NUM] = true
+    end
+    SAVE.COINS[''..SAVE.LEVEL_NUM+SAVE.GREED*0.01] = self.coins
+    SAVE.TIMES[''..SAVE.LEVEL_NUM+SAVE.GREED*0.01] = SAVE.TICK_COUNT - (SAVE.LEVEL_TICK or SAVE.START_TICK)
+    if not SAVE[''..SAVE.LEVEL_NUM+SAVE.GREED*0.01] or SAVE.TICK_COUNT - (SAVE.LEVEL_TICK or SAVE.START_TICK) < SAVE.BEST_TIMES[''..SAVE.LEVEL_NUM+SAVE.GREED*0.01] then
+        SAVE.BEST_TIMES[''..SAVE.LEVEL_NUM+SAVE.GREED*0.01] = SAVE.TICK_COUNT - (SAVE.LEVEL_TICK or SAVE.START_TICK)
+    end
+
+    local cur, section = find_section_index(SAVE.LEVEL_NUM, SAVE.GREED)
+    local i = cur
+
+    print(cur, section)
+    while type(sections[section][i]) ~= 'table' and i < #sections[section] do
+        i = i + 1
+    end
+
+    local t = i - 1
+    local count = 0
+    while t > 0 and type(sections[section][t]) == 'number' do
+        if SAVE.BEAT[''..sections[section][t]] then
+            count = count + 1
+        end
+        t = t - 1
+    end
+
+    print(section, i, sections[section][i])
+    if not SAVE.OPENED[''..section..'-'..i] and ((type(sections[section][i]) == 'table' and sections[section][i].beat and sections[section][i].beat <= count) or i == cur + 1) then
+        save_game()
+        change_scene(LevelSelect:new())
+        return
+    end
+
+    if SAVE.GREED ~= 0 then
+        SAVE.GREED = SAVE.GREED + 1
+        print(inspect(levels[SAVE.LEVEL_NUM]))
+        if #levels[SAVE.LEVEL_NUM].greed < SAVE.GREED then
+            SAVE.GREED = 0
+        end
+    end
+    if greed then
+        print('greeding?')
+        SAVE.GREED = 1
+    end
+    if SAVE.GREED == 0 then
+        SAVE.LEVEL_NUM = SAVE.LEVEL_NUM + 1
+    end
+    SAVE.LEVEL_TICK = SAVE.TICK_COUNT
+    SAVE.COINS_MISSED = SAVE.COINS_MISSED + (self.coin_count or 0)
+    SAVE.TOP_LEVEL = math_max(SAVE.LEVEL_NUM, SAVE.TOP_LEVEL)
+    PERFECT = true
+
+    save_game()
+
+    local gs = GameScene:new()
+    gs.fancy_enter = fancy_enter
+    gs.fancy_exit = fancy_exit
+    change_scene(gs)
+end
