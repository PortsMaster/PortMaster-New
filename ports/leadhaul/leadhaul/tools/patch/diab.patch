+_G.TrackPiece = {} -- Explicit global declaration for strict.lua
+
+local math_min = math.min
+local math_max = math.max
+local L_Object = Object
+
+-- Direction constants (faster than strings)
+local DIR_NEXT = 1
+local DIR_LAST = 2
+
+function TrackPiece:new(o)
+    o = o or {}
+    setmetatable(o, self)
+    self.__index = self
+    o:init()
+    return o
+end
+
+function TrackPiece:init()
+    _, self.sprite = self.ent:add_comp(Sprite, {
+        file = 'res/usable_files/diab_final_tileset.png',
+        w = 16, h = 16,
+        frame = self.tile
+    })
+    self.ent.tag = 'track_piece'
+
+    -- internal state
+    self.update_counter = 0
+    self.started = false
+end
+
+local function get_all(scene, x, y)
+    local start = scene:lookup('Foreground', x, y)
+    if not start or start.taken then return nil end
+
+    local ents = {}
+    local ox   = {}
+    local oy   = {}
+
+    local i = 1
+    local n = 1
+
+    ents[1] = start
+    ox[1] = 0
+    oy[1] = 0
+    start.taken = true
+
+    while i <= n do
+        local ent = ents[i]
+        local offx = ox[i]
+        local offy = oy[i]
+        i = i + 1
+
+        -- Unrolled directions (faster than table loop)
+        local nx, ny, e
+
+        ny = y + offy  -- set once; shared by the +x and -x checks on this row
+
+        nx = x + offx + 16
+        e = scene:lookup('Foreground', nx, ny)
+        if e and not e.taken then
+            n = n + 1
+            ents[n] = e
+            ox[n] = offx + 16
+            oy[n] = offy
+            e.taken = true
+        end
+
+        nx = x + offx - 16
+        e = scene:lookup('Foreground', nx, ny)  -- BUG FIX: was using stale ny from previous iteration
+        if e and not e.taken then
+            n = n + 1
+            ents[n] = e
+            ox[n] = offx - 16
+            oy[n] = offy
+            e.taken = true
+        end
+
+        nx = x + offx
+        ny = y + offy + 16
+        e = scene:lookup('Foreground', nx, ny)
+        if e and not e.taken then
+            n = n + 1
+            ents[n] = e
+            ox[n] = offx
+            oy[n] = offy + 16
+            e.taken = true
+        end
+
+        ny = y + offy - 16
+        e = scene:lookup('Foreground', nx, ny)
+        if e and not e.taken then
+            n = n + 1
+            ents[n] = e
+            ox[n] = offx
+            oy[n] = offy - 16
+            e.taken = true
+        end
+    end
+
+    return ents, ox, oy
+end
+
+function TrackPiece:update()
+    -- Frame skipping (no modulo)
+    local c = self.update_counter + 1
+    if c < 4 then
+        self.update_counter = c
+        return
+    end
+    self.update_counter = 0
+
+    local ent_ref = self.ent
+
+    if not self.started then
+        if not scene then return end
+
+        local lookup_result = scene:lookup('Foreground', ent_ref.x - 8, ent_ref.y)
+        if not lookup_result then
+            return
+        end
+
+        self.started = true
+
+        local ents, ox, oy = get_all(scene, ent_ref.x - 8, ent_ref.y)
+        if not ents then return end
+
+        self.moving_ents = ents
+        self.moving_ox   = ox
+        self.moving_oy   = oy
+
+        local max_left, max_right
+        local single = (#ents == 1)
+
+        for i = 1, #ents do
+            local ent = ents[i]
+            local obj = ent[L_Object] or ent:add_comp(L_Object, {
+                w = 16, h = 16, solid = true
+            })
+
+            if single or not obj.pass_through then
+                local x = ent.x
+                max_left  = max_left  and math_min(max_left, x) or x
+                max_right = max_right and math_max(max_right, x) or x
+            end
+
+            obj.check_list = L_Object.player_list
+        end
+
+        local columns_offset = ((max_right - max_left) / 16) * 8
+        for i = 1, #ox do
+            ox[i] = ox[i] - columns_offset
+        end
+
+        self.direction = DIR_NEXT
+        self.current_piece = self.next_piece or self.last_piece
+        if not self.current_piece then
+            self.direction = DIR_LAST
+            self.current_piece = self.last_piece
+        end
+
+        return
+    end
+
+    local movers = self.moving_ents
+    if not movers or not movers[1] then return end
+
+    local target = self.current_piece
+    if not target then return end
+    local tp_ent = target.ent
+    local base_x = tp_ent.x
+    local base_y = tp_ent.y
+
+    local ox = self.moving_ox
+    local oy = self.moving_oy
+
+    local reached_all = true
+
+    for i = 1, #movers do
+        local ent = movers[i]
+        local obj = ent[L_Object]
+
+        local tx = base_x + ox[i]
+        local ty = base_y + oy[i]
+
+        local cx = ent.x
+        local cy = ent.y
+
+        local dx = tx - cx
+        if dx ~= 0 then
+            obj:move_x(dx > 0 and 1 or -1)
+            reached_all = false
+        end
+
+        local dy = ty - cy
+        if dy ~= 0 then
+            obj:move_y(dy > 0 and 1 or -1)
+            reached_all = false
+        end
+    end
+
+    if reached_all then
+        local n
+        if self.direction == DIR_NEXT then
+            n = target.next_piece
+            if not n then
+                self.direction = DIR_LAST
+                n = target.last_piece
+            end
+        else
+            n = target.last_piece
+            if not n then
+                self.direction = DIR_NEXT
+                n = target.next_piece
+            end
+        end
+        self.current_piece = n
+    end
+end
+
+return TrackPiece
