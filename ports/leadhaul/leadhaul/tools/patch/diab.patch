+function mute(f)
+    muted[f] = true
+end
+
+function unmute(f)
+    muted[f] = false
+end
+
+-- OPTIMIZATION: Pre-build common sound paths to avoid string concatenation
+local sound_cache = {}
+function get_sound_path(sound)
+    if not sound_cache[sound] then
+        sound_cache[sound] = 'res/sfx/'..sound..'.wav'
+    end
+    return sound_cache[sound]
+end
+
+function play_sound(sound, pitch, vol, loop)
+    pitch = pitch or 0
+    if muted[sound] then
+        return
+    end
+    local s = sfx[sound]
+    if not s then
+        s = ripple.newSound(love.audio.newSource(get_sound_path(sound), 'static'), {
+            loop = loop,
+        })
+        sfx[sound] = s
+        last_played[sound] = -1
+    end
+    local tick = SAVE.TICK_COUNT
+    if last_played[sound] == tick then
+        return
+    end
+    last_played[sound] = tick
+    return s:play({
+        volume = SETTINGS.sfx_volume/100 * (vol or 1),
+        pitch = 2^(pitch/12),
+    })
+end
