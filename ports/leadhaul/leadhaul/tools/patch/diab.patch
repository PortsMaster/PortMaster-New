+Saw = {}
+
+function Saw:new(o)
+    o = o or {}
+
+    setmetatable(o, self)
+    self.__index = self
+
+    o:init()
+
+    return o
+end
+
+function Saw:init()
+    _, self.sprite = self.ent:add_comp(Sprite, {
+        file='res/usable_files/saw.png', 
+        w=32, 
+        h=32,
+        frame=0,
+        continue=true
+    })
+    self.sprite:animate({0, 1})
+
+    local w = 12
+    local obj = self.scene:lookup(self.layer, self.ent.x - 40, self.ent.y - 8)
+    if obj and obj[Saw] then
+        w = 32
+    end
+
+    _, self.object = self.ent:add_comp(Object, {
+        w=w,
+        h=12,
+        pass_through=true,
+        check_list=Object.player_list,
+    })
+
+    self.ent.tag = 'saw'
+end
+
+register_tiles({64, 65, 74, 75}, function(scene, tile, x, y, layer)
+    if tile ~= 64 then
+        return
+    end
+
+    -- FIX: spawn at (x+8, y) not (x+8, y+8).
+    -- track_piece looks up the saw in lookup_table using the tile's pixel centre
+    -- (x, y) and then moves it toward TrackPiece.ent.y, which is also ty*16+8 = y.
+    -- The original +8 on y placed the saw 8px below where track_piece expected it,
+    -- so the movement logic could never reach its target and the saw stayed static.
+    return scene:add_entity(Entity:new({
+        x=x+8,
+        y=y,
+        layer=entity_layers[layer.name]
+    }):add_comp(Saw, {scene=scene, layer=layer.name}))
+end)
+
+register_collision('saw', 'player', function(solid, player, solid_x, solid_y, player_x, player_y)
+    local difx = player.x - solid.x
+    if difx > 12 then
+        return false
+    end
+
+    local dify = player.y - solid.y
+    local dis = math.max(math.sqrt(difx * difx + dify * dify), 1)
+
+    scene:restart(difx / dis, dify / dis)
+
+    return false
+end)
