+GravityLine = {}
+
+function GravityLine:new(o)
+    o = o or {}
+
+    setmetatable(o, self)
+    self.__index = self
+
+    o:init()
+
+    return o
+end
+
+function GravityLine:init()
+    _, self.sprite = self.ent:add_comp(Sprite, {
+        file='res/images/tiles_vault.png',
+        w=16,
+        h=16,
+        frame=self.tile
+    })
+
+    _, self.object = self.ent:add_comp(Object, {
+        w=8,
+        h=8,
+        pass_through=true,
+    })
+
+    self.ent.tag = 'gravity_line'
+
+    -- Per-instance cooldown and side state (was incorrectly on the class table,
+    -- causing all gravity lines to share a single timer and side value)
+    self.last_tick = 0
+    self.side = false
+end
+
+register_tiles({}, function(scene, tile, x, y, layer)
+    return scene:add_entity(Entity:new({
+        x=x,
+        y=y,
+        layer=entity_layers[layer.name]
+    }):add_comp(GravityLine, {tile=tile, layer=layer.name}))
+end)
+
+register_collision('gravity_line', 'player', function(solid, player, solid_x, solid_y, player_x, player_y)
+    -- FIX: read/write per-instance state instead of the shared class table
+    local gl = solid[GravityLine]
+
+    if gl.last_tick > SAVE.TICK_COUNT then
+        -- FIX: removed print() which was flushing stdout every frame during collision
+        if gl.side ~= (player.x > solid.x) then
+            gl.side = player.x > solid.x
+            player[Object].gravity = -player[Object].gravity
+            player[Player].vel_y = -player[Player].vel_y
+            player[Sprite].flip_y = not player[Sprite].flip_y
+        end
+
+        return false
+    end
+
+    gl.side = player.x > solid.x
+    gl.last_tick = SAVE.TICK_COUNT + 4
+
+    return false
+end)
