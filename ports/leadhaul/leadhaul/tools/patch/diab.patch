+    -- Get current window dimensions
+    local window_w, window_h = graphics_getDimensions()
+
+    -- Calculate the scale needed to fit the screen
+    -- This finds the ratio for both width and height and picks the smaller one
+    local scale_w = window_w / 640
+    local scale_h = window_h / 360
+    local dynamic_scale = math.min(scale_w, scale_h)
+
+    -- Calculate offsets to keep the canvas perfectly centered
+    local offset_x = (window_w - (640 * dynamic_scale)) / 2
+    local offset_y = (window_h - (360 * dynamic_scale)) / 2
+
+    graphics_setColor(255, 255, 255, FADE)
+    
+    -- Use dynamic_scale and the calculated offsets
+    graphics_draw(main_canvas, offset_x, offset_y, 0, dynamic_scale, dynamic_scale)
