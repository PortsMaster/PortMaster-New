+-- OPTIMIZATION: Flat hash map from tile id -> handler function.
+-- Replaces the old tile_handles array which required a linear tablefind()
+-- scan across ALL registered tiles for EVERY tile in the level on load.
+-- register_tiles() is called at file-load time so this is built once at startup.
+local tile_to_handler = {}
+
+function register_tiles(tiles, fn)
+    for i = 1, #tiles do
+        tile_to_handler[tiles[i]] = fn
+    end
+end
+
+-- OPTIMIZATION: Numeric IDs for each lookup-able layer name.
+-- Used by GameScene:lookup() and load_tile_layer() to form a pure-integer key,
+-- avoiding 3 string concatenations + a heap allocation on every lookup call.
+-- Only layers that are actually written into lookup_table need an entry here.
+local layer_ids = {
+    Foreground  = 1,
+    Collision   = 2,
+    Background  = 3,
+    Background2 = 4,
+    Right       = 5,
+    Left        = 6,
+    Objects     = 7,
