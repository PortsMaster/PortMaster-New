+GameScene.game_update = profile("game_update", function(self)
+    local stop = true
+    self.sleep = self.sleep - 1
+
+    if self.left_ent and self.wall_key_count <= 0 then
+        self.left_vel = math_min(self.left_vel + 0.01, self.heavy_walls and 0.25 or (0.4))
+        self.right_vel = math_max(self.right_vel - 0.01, self.heavy_walls and -0.25 or (-0.4))
+
+        if self.sleep < 0 then
+            if self.left_freeze <= 0 then
+                local move = math_min(self.left_ent and self.right_ent.x - self.left_ent.x - 16 or 1, self.left_vel)
+                move = math_max(move, move)
+                if move == 0 then
+                    self.left_vel = math_max(-1, self.left_vel)
+                end
+                if move < 0 and self.player[Player].sm.state == 'push' then
+                    if not self.sound then
+                        self.sound = play_sound('push_wall', nil, 0.5, true)
+                    end
+                    if SAVE.TICK_COUNT % 4 == 0 then
+                        self.shake = 0.4
+                    end
+                    stop = false
+                end
+                for i, ent in ipairs(self.left_ents) do
+                    ent[Object]:move_x(move)
+                    break
+                end
+            else
+                self.left_freeze = self.left_freeze - 1
+            end
+
+            if self.right_freeze <= 0 then
+                local move = math_max(self.left_ent and self.left_ent.x - self.right_ent.x + 16 or -1, self.right_vel)
+                move = math_min(move, move)
+                if move == 0 then
+                    self.right_vel = math_min(1, self.right_vel)
+                end
+                if move > 0 and self.player[Player].sm.state == 'push' then
+                    if not self.sound then
+                        self.sound = play_sound('push_wall', nil, 0.5, true)
+                    end
+                    if SAVE.TICK_COUNT % 4 == 0 then
+                        self.shake = 0.4
+                    end
+                    stop = false
+                end
+                for i, ent in ipairs(self.right_ents) do
+                    ent[Object]:move_x(move)
+                    break
+                end
+            else
+                self.right_freeze = self.right_freeze - 1
+            end
+        end
+    end
+
+    if stop then
+        if self.sound then
+            self.sound:stop()
+            self.sound = nil
+        end
+    end
+
+    if self.has_goop then
+        self.kill_height_offset = self.kill_height_offset - 0.5
+    end
+end)
