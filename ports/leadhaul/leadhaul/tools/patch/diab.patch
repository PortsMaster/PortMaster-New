+-- Create palette texture from lookup table
+local function create_palette_texture(palette_index)
+    local imageData = love.image.newImageData(256, 1)
+    
+    -- Initialize all pixels to black
+    for i = 0, 255 do
+        imageData:setPixel(i, 0, 0, 0, 0, 1)
+    end
+    
+    -- Set colors from lookup table
+    for k, v in pairs(lookup[palette_index]) do
+        imageData:setPixel(k, 0, v[1], v[2], v[3], 1)
+    end
+    
+    local texture = love.graphics.newImage(imageData)
+    texture:setFilter('nearest', 'nearest')
+    texture:setWrap('clamp', 'clamp')
+    return texture
+end
