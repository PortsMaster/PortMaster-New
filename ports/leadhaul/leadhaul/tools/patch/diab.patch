+FADE_RATE = 1/30
+GameScene.update = profile("GameScene.update", function(self)
+    
+    if pressed('pause') then
+        self.pause_menu = not self.pause_menu
+        self.paused = self.pause_menu
+    end
+
+    -- if pressed('q') then
+    --     love.graphics.captureScreenshot('diab' .. os.time() .. '.png')
+    -- end
+
+    self.fade = math_min(self.fade + FADE_RATE, 1)
+    FADE = self.fade
+
+    if not NO_SKIP then
+        if pressed('p') then
+            self:next()
+        elseif pressed('o') then
+            self:last()
+        end
+    end
+
+    if not self.paused then
+        self:game_update()
+    end
+
+    Scene.update(self)
+
+    for i, ent in ipairs(self.ui_ents) do
+        ent:update()
+    end
+    local i = 1
+    while i <= #self.ui_ents do
+        if self.ui_ents[i].dead then
+            _ = self.ui_ents[i].clean_up and self.ui_ents[i]:clean_up()
+            self.events:remove(self.ui_ents[i])
+            table.remove(self.ui_ents, i)
+        else
+            i = i + 1
+        end
+    end
+
+    if self.pause_menu then
+        self.pause_ents:update()
+    end
+end)
