+function GameScene:calc_width()
+    if not self.max_right or not self.max_left then
+        return 0
+    end
+    return (self.max_right - self.max_left)
+end
+
+function GameScene:calc_height()
+    if not self.max_bot or not self.max_top then
+        return 0
+    end
+    return (self.max_bot - self.max_top)
+end
+
+function GameScene:render(scale, translate_x, translate_y, sc)
+    scale = scale or 1
+    translate_x = translate_x or 0
+    translate_y = translate_y or 0
+    love.graphics.push()
+
+    -- Cache once — these never change mid-frame and were previously called 7x
+    local cw = self:calc_width()
+    local ch = self:calc_height()
+
+    if ch > 30 * 16 then
+        if self.player.y < self.scroll_height - TOP_WINDOW_SCROLL then
+            self.scroll_height = self.player.y + TOP_WINDOW_SCROLL
+        elseif self.player.y > self.scroll_height - BOTTOM_WINDOW_SCROLL then
+            self.scroll_height = self.player.y + BOTTOM_WINDOW_SCROLL
+        end
+
+        if not self.player[StateManager]:attr('air') then
+            self.scroll_to = self.player.y
+        end
+
+        if self.scroll_to then
+            if self.player.y > self.scroll_to then
+                self.scroll_to = nil
+            else
+                self.scroll_height = math_min(math_max(self.scroll_height - 1, self.scroll_to + BOTTOM_WINDOW_SCROLL), self.scroll_height)
+            end
+        end
+
+        self.kill_height = math_min(self.max_top + ch + self.kill_height_offset, self.kill_height)
+        self.scroll_height = math_min(self.scroll_height, self.max_bot + 30)
+        self.scroll_height = math_max(self.scroll_height, self.max_top + 360 + 40)
+    end
+
+    local xs = 0
+    local ys = 0
+
+    if self.shake > 0 or self.shake_left > 0 or self.shake_right > 0 then
+        self.shake = math_max(self.shake - 0.1, 0)
+        self.shake_left = math_max(self.shake_left - 0.1, 0)
+        self.shake_right = math_max(self.shake_right - 0.1, 0)
+
+        local angle = math.pi * math_random() * 2
+
+        xs = math_cos(angle) * (self.shake + self.shake_left - self.shake_right) + (self.shake_left - self.shake_right)
+        ys = math_sin(angle) * (self.shake + self.shake_left - self.shake_right)
+    end
+
+    love.graphics.translate(
+        xs + ((320 - cw/2 - self.max_left)),
+        ys -(self.scroll_height - 30 - math_min(23, ch) * 16)
+    )
+
+    if not sc then
+        love.graphics.setScissor((-cw/2 + 320 + translate_x) * scale, translate_y * 0.5, cw * scale, ch * scale)
+    else
+        love.graphics.setScissor(math_max(374, (-cw/2 + 320 + translate_x) * scale), math_max(20, translate_y * 0.5), math_min(250, cw * scale), math_min(200, ch * scale))
+    end
+
+    Scene.render(self)
+
+    if ch > 30 * 16 and scale == 1 then
+        love.graphics.setColor(161/255, 161/255, 161/255)
+        love.graphics.rectangle('fill', self.max_left, self.kill_height, cw, 400)
+        love.graphics.setColor(1, 1, 1)
+
+        if self.goop_batches then
+            local goop_frame = math_floor(SAVE.TICK_COUNT / 6) % 18
+            if current_shader ~= self.goop[Sprite].shader then
+                love.graphics.setShader(self.goop[Sprite].shader)
+                current_shader = self.goop[Sprite].shader
+            end
+            love.graphics.draw(self.goop_batches[goop_frame], 0, self.kill_height)
+        end
+    end
+
+    -- OPTIMIZATION: Edges drawn as two SpriteBatch calls instead of
+    -- edge_height*2 individual Entity:render() calls per frame.
+    if self.max_right and self.level_data and self.edge_batch_left then
+        local edge_offset = math_floor(math_sin(SAVE.TICK_COUNT/CYCLE_LENGTH) * CYCLE_SIZE) - CYCLE_OFFSET
+
+        -- Rebuild batches only when offset changes (once per tick at most)
+        if edge_offset ~= self.edge_last_offset then
+            self:rebuild_edge_batches(edge_offset)
+        end
+
+        if current_shader ~= self.edge[Sprite].shader then
+            love.graphics.setShader(self.edge[Sprite].shader)
+            current_shader = self.edge[Sprite].shader
+        end
+        love.graphics.setColor(1, 1, 1, 1)
+        love.graphics.draw(self.edge_batch_left,  0, 0)
+        love.graphics.draw(self.edge_batch_right, 0, 0)
+    end
+
+    love.graphics.setScissor()
+    love.graphics.pop()
+
+    if scale ~= 1 then
+        return
+    end
+
+    love.graphics.push()
+
+    local ui_count = #self.ui_ents
+    for i=1, ui_count do
+        self.ui_ents[i]:render()
+    end
+
+    if self.pause_menu then
+        love.graphics.setShader()
+        current_shader = nil
+
+        love.graphics.setColor(0, 0, 0, 0.7)
+        love.graphics.rectangle('fill', 0, 0, 640, 360)
+        love.graphics.setColor(1, 1, 1, 1)
+
+        self.pause_ents:render()
+    end
+
+    love.graphics.pop()
+end
+
+function GameScene:exit()
+    self.lightning = false
+    local i = 1
+    while i <= #self.entities do
+        if true then
+            _ = self.entities[i].clean_up and self.entities[i]:clean_up()
+            self.events:remove(self.entities[i])
+            table.remove(self.entities, i)
+        else
+            i = i + 1
+        end
+    end
+
+    if self.sound then
+        self.sound:stop()
+        self.sound = nil
+    end
+end
+
+function GameScene:find_closest_ents()
+    self.left_ent = self.left_ents[1]
+    self.left_ent_start = self.left_ent and self.left_ent.x or -100000
+    self.right_ent = self.right_ents[1]
+    self.right_ent_start = self.right_ent and self.right_ent.x or 100000
+    local dis = 100000000
+    for i,le in ipairs(self.left_ents) do
+        for i,re in ipairs(self.right_ents) do
+            if re.y == le.y and re.x - le.x < dis and not le[Object].pass_through and not re[Object].pass_through then
+                self.left_ent = le
+                self.left_ent_start = le.x
+                self.right_ent = re
+                self.right_ent_start = re.x
+                dis = re.x - le.x
+            end
+        end
+    end
+
+    if not self.left_ent  then
+        self.left_ent = self:add_entity(Entity:new({x=-100000, y=0}))
+        self.left_ent_start = -100000
+    end
+
+    if not self.right_ent then
+        self.right_ent = self:add_entity(Entity:new({x=100000, y=0}))
+        self.right_ent_start = 100000
+    end
+end
+
+function GameScene:lookup(layer, x, y)
+    -- OPTIMIZATION: Pure-integer key replaces 3 string concatenations per call.
+    -- Formula: (x * 10000 + y) * 100 + layer_id
+    -- Assumes x,y are tile pixel coords (multiples of 16, up to ~10000px levels)
+    -- and layer_id fits in [1..99]. Safe for maps up to 625 tiles wide/tall.
+    return self.lookup_table[(x * 10000 + y) * 100 + layer_ids[layer]]
+end
+
+function GameScene:get_tile(x, y, layer_name)
+    local layer = self.layers[layer_name]
+    return layer.data[x + y * layer.width + 1] - 1
+end
+
+function GameScene:set_tile(x, y, layer_name, t)
+    local layer = self.layers[layer_name]
+    layer.data[x + y * layer.width + 1] = t + 1
+end
+
+function GameScene:load_level(name)
+    self.lookup_table = {}
+
+    local content = love.filesystem.read(name)
+    local level_data = json.decode(content)
+    self.level_data = level_data
+    self.layers = {}
+
+    for i, layer in ipairs(level_data.layers) do
+        if layer.name == "Text" then
+            self:load_text_layer(layer)
+        elseif layer.data then
+            self:load_tile_layer(layer)
+        else
+            for i, obj in ipairs(layer.objects) do
+                local ent = nil
+                local done = false
+                local tile = obj.gid - 1
+
+                local x = obj.x + 8
+                local y = obj.y - 8
+
+                local handler = tile_to_handler[tile]
+                if handler then
+                    done = true
+                    ent = handler(self, tile, obj.x + 8, obj.y - 8, layer)
+                end
+
+                if not done then
+                    ent = self:add_entity(Entity:new({
+                        x=x,
+                        y=y,
+                        layer=entity_layers[layer.name],
+                        tag='solid'
+                    }):add_comp(Sprite, {
+                        file='res/images/tiles_vault.png',
+                        w=16,
+                        h=16,
+                        frame=tile
+                    }))
+
+                    ent:add_comp(Object, {
+                        w=16,
+                        h=16,
+                        solid=true
+                    })
+                end
+
+                -- Write object-layer entities into lookup_table so that
+                -- scene:lookup() can find them (e.g. track_piece finding carts,
+                -- Saw:init() finding adjacent saws). Uses same key formula as
+                -- load_tile_layer. Only writes for known layer names.
+                if ent and layer_ids[layer.name] then
+                    self.lookup_table[(x * 10000 + y) * 100 + layer_ids[layer.name]] = ent
+                end
+            end
+        end
+    end
+
+    self:find_closest_ents()
+
+    if not self.max_left then
+        self.max_left = 0
+    end
+
+    if not self.max_right then
+        self.max_right = self.level_data.width * 16
+    end
+
+    if not self.max_top then
+        self.max_top = 0
+    end
+
+    if not self.max_bot then
+        self.max_bot = self.level_data.height * 16
+    end
+
+    self.kill_height = self.max_bot + 30
+    self.scroll_height = math_min(self.kill_height, self:calc_height() > 28*16 and (self.player.y + BOTTOM_WINDOW_SCROLL) or self.kill_height)
+    if self.kill_height_offset then
+        self.kill_height_offset = self.kill_height_offset - self:calc_height()
+    else
+        self.kill_height_offset = 90
+    end
+
+end
+
+-- Remove static collision entities from self.post (and self.entities if already
+-- moved there). Their Objects remain registered in the spatial hash and continue
+-- to handle solid collision detection — only the scene loop iteration is eliminated.
+--
+-- Safe because:
+--   - Collision tiles never move   -> no hash:update needed
+--   - No Sprite component          -> no render cost anyway
+--   - update already nooped        -> no update cost anyway
+--   - Found via lookup_table       -> direct entity ref, not via scene.entities
+--   - Object._reset() at begin()   -> clears shash on level reload, no leak
+--
+-- Result for go_up:  1908 entities removed from loop -> ~56 remain
+-- Result for cliffside: 585 entities removed from loop -> ~52 remain
+function GameScene:purge_static_collision_entities()
+    local i = #self.post
+    while i >= 1 do
+        if self.post[i]._static_collision then
+            table.remove(self.post, i)
+        end
+        i = i - 1
+    end
+    -- Also sweep self.entities in case render has already moved some across
+    i = #self.entities
+    while i >= 1 do
+        if self.entities[i]._static_collision then
+            table.remove(self.entities, i)
+        end
+        i = i - 1
+    end
+end
+
+-- Build SpriteBatches for the left and right walls.
+-- Also performs three rounds of cleanup that eliminate the remaining per-frame
+-- costs of having 1560 individual wall entities:
+--
+--   A) no_check Objects (interior tiles that can never touch a moving entity)
+--      are removed from the joint and the spatial hash entirely.
+--      Per-pixel joint cost: 780 hash:update calls -> 209.
+--
+--   B) All wall entities except ents[1] are spliced out of scene.entities.
+--      Eliminates 1558 noop update() + 1558 noop render() calls per frame.
+--      ents[1] stays so its Sprite.render (overridden below) fires at the
+--      correct z-order position within Scene.render().
+--
+--   C) ents[1] Object is kept in the joint so ent[1].x tracks movement,
+--      which is the offset used when drawing the batch.
+function GameScene:build_wall_batches()
+    local noop = function() end
+
+    local function build_for(ents, scene_entities)
+        if #ents == 0 then return end
+
+        local first_spr = ents[1][Sprite]
+        if not first_spr then return end
+
+        local image     = first_spr.image
+        local batch     = love.graphics.newSpriteBatch(image, #ents)
+        local initial_x = ents[1].x
+
+        -- Mark every wall entity for removal from scene.entities,
+        -- then unmark ents[1] which must stay for z-ordered batch draw.
+        for _, ent in ipairs(ents) do
+            ent._wall_remove = true
+        end
+        ents[1]._wall_remove = nil
+
+        for i, ent in ipairs(ents) do
+            local s   = ent[Sprite]
+            local obj = ent[Object]
+            if s then
+                local quad = s.quads[(s.frame or 0) + 1]
+                batch:add(quad, ent.x - initial_x, ent.y, 0, 1, 1, s.w/2, s.h/2)
+                s.render = noop
+                if i > 1 then ent.render = noop end
+            end
+            ent.update = noop
+
+            -- A) Strip no_check (interior) Objects from joint and spatial hash.
+            --    They serve no collision purpose so maintaining them is pure waste.
+            --    Keep ents[1] Object in joint so ent.x tracks wall movement.
+            if obj and obj.no_check and i > 1 then
+                obj:clean_up()
+            end
+        end
+
+        -- B) Splice surplus wall entities out of scene.entities.
+        --    Iterate backwards to avoid index shifting.
+        if scene_entities then
+            local i = #scene_entities
+            while i >= 1 do
+                if scene_entities[i]._wall_remove then
+                    table.remove(scene_entities, i)
+                end
+                i = i - 1
+            end
+        end
+
+        -- Override ents[1] Sprite.render to draw entire batch at current x.
+        first_spr.render = function()
+            if current_shader ~= change_shader then
+                love.graphics.setShader(change_shader)
+                current_shader = change_shader
+            end
+            love.graphics.setColor(1, 1, 1, 1)
+            love.graphics.draw(batch, ents[1].x, 0)
+        end
+    end
+
+    -- scene.entities is populated by Scene.render() from scene.post on first render.
+    -- build_wall_batches() is called from begin() before the first render, so
+    -- wall entities are still in self.post. We splice from self.post here;
+    -- ents[1] per wall will be moved to entities naturally on first render.
+    local pool = (#self.entities > 0) and self.entities or self.post
+    build_for(self.left_ents,  pool)
+    build_for(self.right_ents, pool)
+end
+
+-- Build (or rebuild) the left and right edge SpriteBatches.
+-- Called once at load, then each render frame only when edge_offset changes.
+function GameScene:build_edge_batches()
+    if not self.level_data then return end
+
+    local edge_sprite = self.edge[Sprite]
+    local image   = edge_sprite.image
+    local height  = self.level_data.height
+
+    self.edge_batch_left  = love.graphics.newSpriteBatch(image, height)
+    self.edge_batch_right = love.graphics.newSpriteBatch(image, height)
+    self.edge_last_offset = nil  -- force rebuild on first render
+end
+
+-- Rebuild edge batch contents for a given x offset.
+-- Only called when edge_offset changes (once per tick at most).
+function GameScene:rebuild_edge_batches(edge_offset)
+    local edge_sprite = self.edge[Sprite]
+    local quads   = edge_sprite.quads
+    local frame   = edge_sprite.frame or 0
+    local quad    = quads[frame + 1]
+    local height  = self.level_data.height
+    local w       = edge_sprite.w
+    local h       = edge_sprite.h
+
+    local bl = self.edge_batch_left
+    local br = self.edge_batch_right
+    bl:clear()
+    br:clear()
+
+    local lx = self.max_left  + edge_offset
+    local rx = self.max_right - edge_offset
+
+    for i = 1, height do
+        local y = i * 16 - 8
+        -- Left edge: drawn flipped=false  (scaleX=1)
+        bl:add(quad, lx, y, 0, 1, 1, w/2, h/2)
+        -- Right edge: drawn flipped=true  (scaleX=-1, origin at w/2)
+        br:add(quad, rx, y, 0, -1, 1, w/2, h/2)
+    end
+
+    self.edge_last_offset = edge_offset
+end
+
+-- Build one SpriteBatch per animation frame at load time.
+-- Each batch is a complete static row of goop sprites for that frame.
+-- No per-frame CPU work — render just picks the right batch by index.
+function GameScene:build_goop_batch()
+    if not self.has_goop then return end
+
+    local goop_sprite = self.goop[Sprite]
+    local image  = goop_sprite.image
+    local quads  = goop_sprite.quads
+    local w      = goop_sprite.w
+    local h      = goop_sprite.h
+    local cw     = self:calc_width()
+    local count  = math_floor(cw / 32) + 1
+    local frames = 18
+
+    self.goop_batches = {}
+    for frame = 0, frames - 1 do
+        local batch = love.graphics.newSpriteBatch(image, count)
+        local quad  = quads[frame + 1]
+        for i = 1, count do
+            batch:add(quad, i * 32 + self.max_left, 0, 0, 1, 1, w/2, h/2)
+        end
+        self.goop_batches[frame] = batch
+    end
+end
+
+function GameScene:load_text_layer(layer)
+    for i, o in ipairs(layer.objects) do
+        self:add_entity(Entity:new({
+            x=o.x+8,
+            y=o.y-8,
+            layer=entity_layers.Foreground,
+            tag='text',
+            update=function(self)
+                if inside(self, scene.player) then
+                    self[Sprite].frame = 63
+                    if pressed('w') then
+                        make_text(o.properties[1].value, true)
+                    end
+                else
+                    self[Sprite].frame = -1
+                end
+            end
+        }):add_comp(Object, {
+            w=16,
+            h=16,
+            pass_through=true
+        }):add_comp(Sprite, {
+            file='res/usable_files/diab_final_tileset.png',
+            w=16,
+            h=16,
+            frame=-1
+        }))
+    end
+end
+
+local tile_check_vals = {}
+
+function GameScene:check_adjacent_tiles(tile_x, tile_y, layer_name, layer_width, layer_height)
+    -- Reuse the same table instead of creating new ones
+    tile_check_vals[1] = self:get_tile(tile_x, tile_y, layer_name)
+    tile_check_vals[2] = self:get_tile(tile_x - 1, tile_y, layer_name)
+    tile_check_vals[3] = self:get_tile(tile_x + 1, tile_y, layer_name)
+    tile_check_vals[4] = self:get_tile(tile_x, tile_y - 1, layer_name)
+    tile_check_vals[5] = self:get_tile(tile_x, tile_y + 1, layer_name)
+
+    local t_val = tile_check_vals[1]
+    for i = 2, 5 do
+        if tile_check_vals[i] ~= t_val then
+            return false
+        end
+    end
+    return true
+end
+
+function GameScene:load_tile_layer(layer)
+    if layer.name == 'RIght' then
+        layer.name = 'Right'
+    end
+    if layer.name == 'Background 2' then
+        layer.name = 'Background2'
+    end
+    self.layers[layer.name] = layer
+
+    local sprite_batch = Sprite:new({
+        file='res/usable_files/diab_final_tileset.png',
+        w=16,
+        h=16,
+    })
+
+    self.main_batch = self:add_entity(Entity:new({
+        x=0,
+        y=0,
+        layer=entity_layers[layer.name]
+    }):add_comp(SpriteBatch, {
+        image=sprite_batch.image,
+        shader=change_shader
+    }))
+    local batch = self.main_batch[SpriteBatch]
+
+    for t, tile in ipairs(layer.data) do
+        tile = tile - 1
+        if tile >= 0 then
+            local tile_x = ((t-1)%layer.width)
+            local tile_y = math_floor((t-1)/layer.width)
+            local x = ((t-1)%layer.width)*16 + 8
+            local y = math_floor((t-1)/layer.width)*16 + 8
+
+            local ent = nil
+            local done = false
+            local handler = tile_to_handler[tile]
+            if handler then
+                done = true
+                local skip = false
+                ent, skip = handler(self, tile, x, y, layer)
+                if skip then
+                    done = false
+                end
+            end
+
+            if not done then
+                ent = self:add_entity(Entity:new({
+                    x=x,
+                    y=y,
+                    layer=entity_layers[layer.name],
+                    tag='solid'
+                }))
+
+                if layer.name == 'Left' or layer.name == 'Right' then
+                    ent:add_comp(Sprite, {
+                        file='res/usable_files/diab_final_tileset.png',
+                        w=16,
+                        h=16,
+                        frame=tile
+                    })
+                else
+                    batch.batch:add(sprite_batch.quads[tile + 1], x, y, 0, 1, 1, 8, 8)
+                end
+
+                if layer.name == 'Collision' then
+                    local done = false
+                    if tile_x > 0 and tile_x < layer.width - 1 and
+                       tile_y > 0 and tile_y < layer.height - 1 then
+                        done = self:check_adjacent_tiles(tile_x, tile_y, layer.name, layer.width, layer.height)
+                    end
+
+                    if not done then
+                        ent:add_comp(Object, {
+                            w=16,
+                            h=16,
+                            solid=true
+                        })
+                    end
+                    -- Collision tiles are static — their Objects live in the spatial
+                    -- hash for collision detection but the entities themselves serve
+                    -- no purpose in scene.entities. Flag them for removal after load.
+                    -- update is nooped as a belt-and-braces safety measure in case
+                    -- anything re-adds them to the loop before removal completes.
+                    ent.update = function() end
+                    ent._static_collision = true
+                elseif layer.name == 'Right' then
+                    local done = false
+                    if tile_x > 0 and tile_x < layer.width - 1 and
+                       tile_y > 0 and tile_y < layer.height - 1 then
+                        done = self:check_adjacent_tiles(tile_x, tile_y, layer.name, layer.width, layer.height)
+                    end
+
+                    if not done then
+                        ent:add_comp(Object, {
+                            w=16,
+                            h=16,
+                            solid=true
+                        })
+                    else
+                        ent:add_comp(Object, {
+                            w=16,
+                            h=16,
+                            solid=true,
+                            no_check=true,
+                        })
+                    end
+                elseif layer.name == 'Left' then
+                    local done = false
+                    if tile_x > 0 and tile_x < layer.width - 1 and
+                       tile_y > 0 and tile_y < layer.height - 1 then
+                        done = self:check_adjacent_tiles(tile_x, tile_y, layer.name, layer.width, layer.height)
+                    end
+
+                    if not done then
+                        ent:add_comp(Object, {
+                            w=16,
+                            h=16,
+                            solid=true
+                        })
+                    else
+                        ent:add_comp(Object, {
+                            w=16,
+                            h=16,
+                            solid=true,
+                            no_check=true,
+                        })
+                    end
+                end
+            end
+
+            if ent then
+                -- OPTIMIZATION: Integer key matches GameScene:lookup() — no string alloc.
+                self.lookup_table[(x * 10000 + y) * 100 + layer_ids[layer.name]] = ent
+                if layer.name == 'Right' then
+                    if ent[Object] then
+                        ent[Object]:set_position(ent.x, ent.y)
+                        ent.right = true
+                        ent[Object].check_list = Object.object_and_player_list
+                        ent[Object].joint = self.right_objs
+                        table_insert(self.right_ents, ent)
+                        table_insert(self.right_objs, ent[Object])
+                    end
+                elseif layer.name == 'Left' then
+                    if ent[Object] then
+                        ent[Object]:set_position(ent.x, ent.y)
+                        ent.left = true
+                        ent[Object].check_list = Object.object_and_player_list
+                        ent[Object].joint = self.left_objs
+                        table_insert(self.left_ents, ent)
+                        table_insert(self.left_objs, ent[Object])
+                    end
+                end
+            end
+        end
+    end
+end
+
+register_tiles({90}, function(scene, tile, x, y, layer)
