+
+    if not no_sound then
+        play_sound("DIABHitBySpikes")
+    end
+    self.sm:change_state('squash')
+end
+
+function Player:win(fancy)
+    if self.sm.state == 'exit' then
+        return
+    end
+    self.sm:change_state(fancy and 'exit_fancy' or 'exit')
+end
+
+function Player:walljump(vel_y, vel_x, vel_wall, lock, state)
+    if not self.wall then
+        return
+    end
+    self.vel_y = vel_y + math_min(self.wall.move_y_amount * WALL_VEL_MULT, 0)
+    self.vel_x = vel_x * self.wall_direction + self.wall.move_x_amount
+    self.sm:change_state(state or 'walljump')
+    if state then
+        play_sound('DIABHyperJump')
+
+        scene:add_entity(Entity:new({
+            x=self.ent.x,
+            y=self.ent.y,
+            layer=self.ent.layer
+        }):add_comp(Particle, {
+            file='res/images/particles.png', 
+            w=80, 
+            h=80,
+            frames={28, 29, 30, 31, 32, 33, 34},
+            flip=self.object.facing == -1,
+            other=self.wall.ent
+        }))
+
+        if self.object.facing == -1 then
+            scene.shake_right = 1
+        else
+            scene.shake_left = 1
+        end
+    else
+        play_sound('DIABJump')
+
+        scene:add_entity(Entity:new({
+            x=self.ent.x,
+            y=self.ent.y,
+            layer=self.ent.layer
+        }):add_comp(Particle, {
+            file='res/images/particles.png', 
+            w=80, 
+            h=80,
+            frames={56, 57},
+            flip=self.object.facing == 1,
+            other=self.wall.ent
+        }))
+    end
+
+    scene.events:trigger('walljump', {entity=self.ent, off=self.wall.ent, push=-self.wall_direction * vel_wall})
+    if self.wall2 then
+        scene.events:trigger('walljump', {entity=self.ent, off=self.wall2.ent, push=-self.wall_direction * vel_wall})
+    end
+    if self.wall3 then
+        scene.events:trigger('walljump', {entity=self.ent, off=self.wall3.ent, push=-self.wall_direction * vel_wall})
+    end
+    if self.wall.ent.left or self.wall.ent.right then
+        scene:push(self.wall.ent.left, self.wall.ent.left and -vel_wall or vel_wall)
+        -- play_sound("jump_off_wall", nil, state and 0.5 or 0.2)
+    end
+
+    if self.hit_left_wall then
+        self.left_lock = lock
+        self.right_lock = 0
+    else
+        self.right_lock = lock
+        self.left_lock = 0
+    end
+    self.hit_wall = false
+    self.hit_left_wall = false
+    self.hit_right_wall = false
+end
+
+function Player.is_riding(self, other, axis)
+    local s = other.ent[Sword]
+    if s then
+        if s.vel_x ~= 0 then
+            return false
+        end
+    end
+
+    if math_abs(other.ent.x - self.ent.x) == (self.w + other.w)/2 then
+        if self.ent[Player].sm:attr('air') or (axis == 'x' and self.ent[Player].sm.state == 'push') then
+            return self
+        else
+            return false
+        end
+    end
+
+    if self.ent.y < other.ent.y then
+        return self
+    end
+end
+
+function Player:grounded_update(sm)
+    local target = 0
+    local max_vel = 2
+
+    local wall = self.object:touch_wall()
+
+    local run = self.on_rope and 'rope_run' or 'run'
+    local idle = self.on_rope and 'rope_idle' or 'idle'
+
+    if down('a') and down('d') then
+        self.vel_x = approach(self.vel_x, 0, 0.4)
+        if sm.state ~= 'enter_cont' then
+            sm:change_state(idle)
+        end
+    elseif down('a') then
+        sm:change_state(wall and 'push' or run)
+        self.vel_x = approach(self.vel_x, -max_vel * (self.on_rope and 0.5 or 1), 0.4 * (self.on_rope and 0.5 or 1))
+        self.object.facing = -1
+    elseif down('d') then
+        sm:change_state(wall and 'push' or run)
+        self.vel_x = approach(self.vel_x, max_vel * (self.on_rope and 0.5 or 1), 0.4 * (self.on_rope and 0.5 or 1))
+        self.object.facing = 1
+    else
+        self.vel_x = approach(self.vel_x, 0, 0.4)
+        if sm.state ~= 'enter_cont' then
+            sm:change_state(idle)
+        end
+    end
+
+    if pressed('space') then
+        local res = self.object:touch_floor()
+        if res then
+            self.vel_y = -4 + math_min(res.move_y_amount * WALL_VEL_MULT, 0)
+            self.vel_x = self.vel_x + res.move_x_amount
+            sm:change_state('up')
+            
+            scene.events:trigger('jump', {entity=self.ent, off=res.ent})
+            play_sound('DIABJump')
+
+            scene:add_entity(Entity:new({
+                x=self.ent.x,
+                y=self.ent.y-12,
+                layer=self.ent.layer
+            }):add_comp(Particle, {
+                file='res/images/particles.png', 
+                w=80, 
+                h=80,
+                frames={7, 8},
+                flip=self.object.facing == -1
+            }))
+        end
+    end
+
+    self:move_update(sm)
+end
+
+function Player:air_update(sm)
+    if self.sm.state ~= 'fancy_fall' then
+        local target = 0
+        local max_vel = sm:attr('super') and not self.cancel and 3 or 2
+        local target_vel = 2
+        if self.vel_x > max_vel then
+            self.vel_x = approach(self.vel_x, max_vel, 0.1)
+        elseif self.vel_x < -max_vel then
+            self.vel_x = approach(self.vel_x, -max_vel, 0.1)
+        elseif down('a') and down('d') then
+        elseif down('a') and self.left_lock <= 0 then
+            if self.vel_x > -target_vel then
+                self.vel_x = approach(self.vel_x, -target_vel, 0.3)
+            end
+        elseif down('d') and self.right_lock <= 0 then
+            if self.vel_x < target_vel then
+                self.vel_x = approach(self.vel_x, target_vel, 0.3)
+            end
+        elseif (self.vel_x > 0 and self.left_lock <= 0) or (self.vel_x < 0 and self.right_lock <= 0) then
+        end
+
+        if pressed('space') then
+            -- wall_coyote_ticks > 0 gives a short grace window after leaving a wall,
+            -- so a walljump input that arrives 1-6 frames late still fires correctly.
+            -- Walljump always takes priority over moth jump during the coyote window.
+            if self.hit_wall or self.wall_coyote_ticks > 0 then
+                self:walljump(-3.6, 2, scene.heavy_walls and 0.5 or 0.65, 20)
+                self.wall_coyote_ticks = 0  -- consume the coyote window immediately
+            elseif self.moth_jump_enabled then
+                sm:change_state('super')
+            end
+        elseif pressed('k') and self.pick_enabled and self.sm.state ~= 'after_climb_jump' then
+            sm:change_state('pre_climb_jump')
+        end
+    end
+
+    self:move_update(sm)
+end
+
+function Player:move_update(sm)
+    if self.sm.state == 'rebound' or self.sm.state == 'climb_jump' then
+    elseif self.sm.state == 'slide' and self.vel_y >= 0 then
+        if SAVE.TICK_COUNT % 12 == 0 then
+            scene:add_entity(Entity:new({
+                x=self.ent.x,
+                y=self.ent.y,
+                layer=self.ent.layer
+            }):add_comp(Particle, {
+                file='res/images/particles.png', 
+                w=80, 
+                h=80,
+                frames={59, 60},
+                flip=self.object.facing == -1,
+                other=self.wall.ent
+            }))
+        end
+        self.vel_y = self.vel_y + GRAVITY_SLIDE
+    else
+        self.vel_y = self.vel_y + 0.15
+    end
+
+    if self.vel_y + self.ent.y < -10 then
+        self.vel_y = -10 - self.ent.y
+    end
+
+    self.hit_wall = false
+    self.hit_left_wall = false
+    self.hit_right_wall = false
+
+    local old_y = self.ent.y
+
+    if not self.roping then
+        self.object:move_x(self.vel_x)
+    end
+    self.on_rope = false
+    if self.roping then
+        self.object:move_y(2)
+    else
+        self.object:move_y(self.vel_y)
+    end
+
+    self:check_wall()
+    if self.state == 'rebound' then
+        return
+    end
+
+    if self.object.move_y_amount ~= 0 then
+        if (0 < (self.ent.y - old_y) * self.object.gravity and self.sm.state ~= 'slide') then
+            self.sm:change_state('down')
+        elseif 0 > (self.ent.y - old_y) * self.object.gravity and not self.sm:attr('air') then
+            self.sm:change_state('up')
+        end
+    end
+end
+
+function Player:check_wall()
+    local obj, obj2, obj3 = self.object:touch_wall()
+    if obj then
+        self.hit_left_wall = obj.ent.x < self.ent.x
+        self.hit_right_wall = obj.ent.x > self.ent.x
+        self.hit_wall = true
+        self.wall_direction = self.hit_left_wall and 1 or -1
+        self.wall = obj
+        self.wall2 = obj2
+        self.wall3 = obj3
+        self.wall_coyote_ticks = 0  -- touching wall resets coyote window
+
+        if self.sm:attr('air') then
+            if self.sm.state == 'super' or self.sm.state == 'super_loop' then
+                self.sm:change_state('rebound')
+            else
+                self.sm:change_state('slide')
+            end
+        end
+    else
+        if self.sm.state == 'slide' then
+            -- Start coyote window: player just left the wall, give 6 ticks
+            -- to still fire a walljump (matches original wall_cling_duration intent)
+            self.wall_coyote_ticks = 6
+            self.sm:change_state(self.vel_y > 0 and 'down' or 'up')
+        end
+    end
+end
+
+function Player:update()
+    self.left_lock = self.left_lock - 1
+    self.right_lock = self.right_lock - 1
+
+    if self.wall_coyote_ticks > 0 then
+        self.wall_coyote_ticks = self.wall_coyote_ticks - 1
+    end
+
+    if self.ent.y > scene.kill_height and self.sm.state ~= 'squash' and self.sm.state ~= 'exit' then
+        -- play_sound('Fall_Off_'..math.random(2))
+        scene:restart(0, -1, true)
+    end
+
+    -- Tick down active ghost pool slots — skipped entirely when none are active
+    if self.ghost_active_count > 0 then
+        local pool = self.ghost_pool
+        for i = 1, GHOST_POOL_SIZE do
+            local g = pool[i]
+            if g.active then
+                g.life = g.life - 1
+                if g.life <= 0 then
+                    g.active = false
+                    self.ghost_active_count = self.ghost_active_count - 1
+                end
+            end
+        end
+    end
+end
+
+function Player:render()
+    -- Skip entirely when no ghosts are alive — avoids all loop and state overhead
+    if self.ghost_active_count == 0 then return end
+
+    local pool  = self.ghost_pool
+    local drawn = false
+
+    for i = 1, GHOST_POOL_SIZE do
+        local g = pool[i]
+        if g.active and g.frame >= 0 then
+            local spr = self.sprite
+            if not drawn then
+                if current_shader ~= spr.shader then
+                    love.graphics.setShader(spr.shader)
+                    current_shader = spr.shader
+                end
+                drawn = true
+            end
+            love.graphics.setColor(1, 1, 1, g.alpha)
+            love.graphics.draw(
+                spr.image,
+                spr.quads[g.frame + 1],
+                g.x + g.offset_x * (g.flip   and -1 or 1),
+                g.y + g.offset_y * (g.flip_y  and -1 or 1),
+                0,
+                g.flip   and -1 or 1,
+                g.flip_y and -1 or 1,
+                spr.w/2, spr.h/2
+            )
+        end
+    end
+
+    if drawn then
+        love.graphics.setColor(1, 1, 1, 1)
+    end
+end
+
+return Player
