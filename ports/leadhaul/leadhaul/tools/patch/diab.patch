+function GameScene:move_wall(is_left, amount)
+    if is_left then
+        for i, ent in ipairs(self.left_ents) do
+            ent[Object]:move_x(amount, false)
+            ent[Object].x_remainder = 0
+        end
+        self.left_freeze = 8
+    else
+        for i, ent in ipairs(self.right_ents) do
+            ent[Object]:move_x(amount, false)
+            ent[Object].x_remainder = 0
+        end
+        self.right_freeze = 8
+    end
+end
