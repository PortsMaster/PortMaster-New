+    o.rot = o.rot or 0
+    o.image, o.quads, o.w, o.h = create_sprite(o.file, o.w, o.h, o.off_x, o.off_y, o.limit_x, o.limit_y)
+    o.shader = not o.noshader and change_shader or nil
+    return o
+end
+
+function Sprite:animate(frames, callback)
+    self.f = 0
+    self.frames = frames
+    self.callback = callback
+    self.frame = self.frames[1]
+end
+
+function Sprite:animate_wait(frames)
+    self.callback = function()
+        signal('done', self)
+    end
+    self:animate(frames, self.callback)
+    waitSignal('done', self)
+end
+
+function Sprite:update()
+    if self.frames then
+        self.f = self.f + 1
+        if self.f >= (#self.frames) * (self.anim_length or 6) then
+            if not self.continue then
+                self.frames = nil
+            else
+                self.f = 0
+            end
+            if self.callback then
+                self.callback()
+            end
+        else
+            self.frame = self.frames[math.floor(self.f / (self.anim_length or 6)) + 1]
+        end
+    end
+end
+
+current_shader = nil
+function Sprite:render()
+    if self.frame < 0 then
+        return
+    end
+    if current_shader ~= self.shader then
+        love.graphics.setShader(self.shader)
+        current_shader = self.shader
+    end
+
+    local xs = 0
+    local ys = 0
+
+    love.graphics.setColor(1, 1, 1, self.alpha or 1)
+    love.graphics.draw(
+        self.image, 
+        self.quads[self.frame + 1], 
+        xs+self.ent.x+(self.offset_x)*(self.flip and -1 or 1),
+        ys+self.ent.y+(self.offset_y)*(self.flip_y and -1 or 1),
+        self.rot,
+        self.flip and -1 or 1, 
+        self.flip_y and -1 or 1, 
+        self.origin_x or self.w/2, 
+        self.origin_y or self.h/2
+    )
+end
